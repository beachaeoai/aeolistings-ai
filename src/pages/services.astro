---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';
import { services } from '../lib/services';

// Service schema (one entry per service)
const serviceSchemas = services.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.name,
  description: s.summary,
  provider: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  serviceType: 'Answer Engine Optimization',
  areaServed: site.location,
}));

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: site.url,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Services',
      item: `${site.url}/services`,
    },
  ],
};

const process = [
  {
    num: '01',
    title: 'Audit',
    description:
      'We run your brand through every major answer engine, map current citation share, and surface the entity and retrieval gaps that keep you out of answers.',
  },
  {
    num: '02',
    title: 'Build',
    description:
      'We implement schema, restructure high-leverage pages, and publish the entity-dense answer content retrieval systems actually chunk and cite.',
  },
  {
    num: '03',
    title: 'Monitor',
    description:
      'A recurring prompt set runs against ChatGPT, Claude, Perplexity, Gemini, and AI Overviews. You see citation share, sentiment, and competitor presence every month.',
  },
  {
    num: '04',
    title: 'Iterate',
    description:
      'Models and surfaces change weekly. We refresh content, adjust schema, and respond to shifts before they cost you the answer slot.',
  },
];
---
<Base
  title="Services"
  description="Four Answer Engine Optimization services — entity foundation, answer-ready content, AEO measurement, and ongoing retainer — engineered to make your business the canonical answer LLMs return."
  path="/services"
  schema={[...serviceSchemas, breadcrumbSchema]}
>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section class="relative border-b border-[color:var(--color-hairline)]">
    <Container class="py-16 md:py-28 lg:py-36">
      <div class="mono-label flex items-center gap-3">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--color-accent)] animate-pulse" aria-hidden="true"></span>
        <span>[ Services / Overview ]</span>
      </div>

      <h1 class="mt-8 font-medium tracking-[-0.02em] leading-[1.05] text-balance"
          style="font-size: var(--text-display);">
        Four disciplines.<br />
        One surface:
        <span class="relative inline-block">
          the answer.
          <span class="absolute left-0 -bottom-2 h-[6px] w-full bg-[color:var(--color-accent)]" aria-hidden="true"></span>
        </span>
      </h1>

      <p class="mt-10 max-w-2xl text-lg md:text-xl text-[color:var(--color-fg-muted)] text-balance">
        Answer Engine Optimization is the work of making your business the single source a generative model
        retrieves, trusts, and quotes. Each service below is a lever on that outcome — used alone, or
        stacked as a full retainer.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="/contact" class="btn btn--primary">
          Start a project
          <span aria-hidden="true">→</span>
        </a>
        <a href="/#faq" class="btn">
          Read the FAQ
        </a>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       DEFINITION — What is AEO?
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-10">
        <div>
          <div class="mono-label">[ 01 / Definition ]</div>
          <h2 class="mt-4 font-medium tracking-[-0.02em] leading-[1.05]"
              style="font-size: var(--text-h1);">
            What is AEO?
          </h2>
        </div>
        <div class="space-y-6 text-lg leading-relaxed">
          <p>
            <strong class="font-medium">Answer Engine Optimization (AEO)</strong> is the practice of
            structuring a business&rsquo;s entity data, content, and technical signals so that large
            language models &mdash; ChatGPT, Claude, Perplexity, Google&rsquo;s AI Overviews, Gemini
            &mdash; return that business as the answer when users ask a buying-intent question.
          </p>
          <p class="text-[color:var(--color-fg-muted)]">
            Traditional SEO optimizes for a ranked list of blue links. AEO optimizes for a single
            synthesized response. The unit of success is no longer a position on page one &mdash;
            it is a <em class="text-[color:var(--color-accent)] not-italic">citation</em> inside the
            model&rsquo;s answer.
          </p>
          <p class="text-[color:var(--color-fg-muted)]">
            Getting there requires a specific stack: machine-readable entity schema, retrieval-friendly
            content architecture, presence across the corpora LLMs train and retrieve from, and
            ongoing measurement of citation share across every major answer surface.
          </p>
          <div class="pt-4 flex flex-wrap gap-2">
            <span class="tag">Entity graph</span>
            <span class="tag">Retrieval-ready</span>
            <span class="tag">Citation share</span>
            <span class="tag tag--accent">AEO</span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       SERVICES DETAIL — full-width rows per service
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="mono-label">[ 02 / Services ]</div>
      <h2 class="mt-4 font-medium tracking-[-0.02em] leading-[1.05]"
          style="font-size: var(--text-display);">
        The stack.
      </h2>

      <div class="mt-16">
        {services.map((s, i) => (
          <article
            id={s.id}
            class:list={[
              'grid md:grid-cols-[1fr_2fr] gap-10 py-12 md:py-16',
              i > 0 ? 'border-t border-[color:var(--color-hairline)]' : '',
            ]}
          >
            <div>
              <div class="mono-label text-base md:text-lg">[{s.num}]</div>
              <h3 class="mt-4 text-3xl md:text-4xl font-medium tracking-tight leading-tight">
                {s.name}
              </h3>
              <p class="mt-4 text-[color:var(--color-accent)] font-[family-name:var(--font-mono)] text-sm leading-relaxed">
                {s.tagline}
              </p>
            </div>

            <div class="space-y-8">
              <p class="text-lg leading-relaxed text-[color:var(--color-fg-muted)]">
                {s.summary}
              </p>

              <div>
                <div class="mono-label mb-4">[ Deliverables ]</div>
                <ul class="border-t border-[color:var(--color-hairline)]">
                  {s.deliverables.map((d) => (
                    <li class="flex items-start gap-4 py-3 border-b border-[color:var(--color-hairline)]">
                      <span class="font-[family-name:var(--font-mono)] text-[color:var(--color-accent)] text-sm pt-1 shrink-0" aria-hidden="true">▸</span>
                      <span class="leading-relaxed">{d}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <!-- =========================================================
       PROCESS
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="mono-label">[ Process ]</div>
      <h2 class="mt-4 font-medium tracking-[-0.02em] leading-[1.05]"
          style="font-size: var(--text-display);">
        Audit. Build. Monitor. Iterate.
      </h2>

      <div class="mt-12 grid md:grid-cols-4 grid-divide grid-divide--md-cols">
        {process.map((step, i) => (
          <div class:list={[
            'py-8 md:py-0',
            i === 0 ? 'md:pr-8' : '',
            i > 0 && i < process.length - 1 ? 'md:px-8' : '',
            i === process.length - 1 ? 'md:pl-8' : '',
          ]}>
            <div class="font-[family-name:var(--font-mono)] text-[color:var(--color-fg-muted)] text-xs tracking-[0.08em]">
              STEP {step.num}
            </div>
            <h3 class="mt-4 text-2xl font-medium tracking-tight leading-tight">
              {step.title}
            </h3>
            <p class="mt-3 text-[color:var(--color-fg-muted)] leading-relaxed">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FINAL CTA
       ========================================================= -->
  <section>
    <Container class="py-24 md:py-36 text-center">
      <div class="mono-label">[ End of line ]</div>
      <h2 class="mt-6 font-medium tracking-[-0.02em] leading-[0.95] text-balance mx-auto max-w-4xl"
          style="font-size: var(--text-display);">
        Ready to become the answer <br class="hidden md:block"/> in your category?
      </h2>
      <div class="mt-10 flex justify-center flex-wrap gap-4">
        <a href="/contact" class="btn btn--primary">
          Start a project
          <span aria-hidden="true">→</span>
        </a>
        <a href="/" class="btn">
          Back to home
        </a>
      </div>
    </Container>
  </section>
</Base>
