---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';
import { services } from '../lib/services';

// Service schema (one entry per service)
const serviceSchemas = services.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.name,
  description: s.summary,
  provider: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  serviceType: 'Answer Engine Optimization',
}));

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${site.url}/services` },
  ],
};

const process = [
  {
    num: '01',
    title: 'Audit',
    description:
      "We run your business through every major AI chatbot — ChatGPT, Google AI, Perplexity, Claude, Gemini — with the questions your real customers ask. You'll see exactly where you stand and where your competitors beat you.",
  },
  {
    num: '02',
    title: 'Build',
    description:
      "We rebuild the foundation AI needs to trust you: Google Business Profile, consistent citations across 30+ directories, schema.org markup, and a canonical business description that lines up everywhere on the web.",
  },
  {
    num: '03',
    title: 'Write',
    description:
      "We rewrite your service pages, FAQ, and location pages so AI can cleanly quote them. Clear answers to real questions — the kind of content an AI assistant can drop into a conversation with your name attached.",
  },
  {
    num: '04',
    title: 'Monitor',
    description:
      "Every month we run the same prompts and report what's changed. When a model updates or a competitor gets aggressive, we adjust. You stay ahead — and you always know where you stand.",
  },
];
---
<Base
  title="Services"
  description="Four Answer Engine Optimization services for home service pros and local professionals: Local AI Audit, Get Listed Get Cited, Answer-Ready Pages, and an ongoing retainer."
  path="/services"
  schema={[...serviceSchemas, breadcrumbSchema]}
>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-32">
      <div class="mono-label">Services · Overview</div>

      <h1 class="mt-8 text-balance max-w-[22ch]"
          style="font-family: var(--font-serif); font-size: var(--text-display); line-height: 1.02;">
        Four services. One outcome: your business gets recommended.
      </h1>

      <p class="mt-10 max-w-2xl text-lg md:text-xl leading-[1.6] text-[color:var(--color-fg-muted)]">
        Answer Engine Optimization is the work of making your business the name AI
        chatbots return when a prospect asks for a recommendation. Each service below is a
        lever on that outcome — used alone, or stacked as a full retainer.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="/contact" class="btn btn--primary">
          <span>Start a project</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/#faq" class="btn">
          <span>Read the FAQ</span>
        </a>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       DEFINITION — What is AEO, in plain English?
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">01 · The short version</div>
          <h2 class="mt-5"
              style="font-size: var(--text-h1); line-height: 1.05;">
            What is AEO, really?
          </h2>
        </div>
        <div class="max-w-[60ch] space-y-6 text-[1.0625rem] leading-[1.65]">
          <p>
            <strong class="font-semibold">Answer Engine Optimization</strong> — AEO — is how you
            get recommended by AI chatbots. When someone asks ChatGPT, Google AI, Perplexity,
            Claude, or Gemini "who's the best roofer near me," the AI gives them an
            answer. Sometimes one name. Sometimes two or three. Almost never a list of ten.
          </p>
          <p class="text-[color:var(--color-fg-muted)]">
            Our work is making sure the name is yours. We build the signals that AI models use
            to decide who they trust enough to mention — then we keep those signals in
            shape as the models change.
          </p>
          <blockquote class="pullquote">
            Traditional SEO gets your website listed. AEO gets your business <em>named</em>.
          </blockquote>
          <p class="text-[color:var(--color-fg-muted)]">
            SEO and AEO aren't enemies. Most of what we build — consistent business data,
            structured content, clear answers to buyer questions — helps both. But the
            surfaces are different, and the signals each rewards are different. We focus on
            the AI chatbot surface because almost nobody else is.
          </p>
          <div class="pt-4 flex flex-wrap gap-2">
            <span class="tag">Citations</span>
            <span class="tag">Structured data</span>
            <span class="tag">Answer-ready content</span>
            <span class="tag tag--accent">AEO</span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       SERVICES DETAIL — full-width rows per service
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="mono-label">02 · The services</div>
      <h2 class="mt-5"
          style="font-size: var(--text-display); line-height: 1.05;">
        The stack.
      </h2>

      <div class="mt-16">
        {services.map((s, i) => (
          <article
            id={s.id}
            class:list={[
              'grid md:grid-cols-[1fr_2fr] gap-10 md:gap-16 py-14 md:py-20',
              i > 0 ? 'border-t border-[color:var(--color-hairline)]' : '',
            ]}
          >
            <div>
              <div class="mono-label">{s.num}</div>
              <h3 class="mt-4 font-[family-name:var(--font-serif)] text-[2rem] md:text-[2.5rem] leading-[1.05] tracking-[-0.01em]">
                {s.name}
              </h3>
              <p class="mt-5 font-[family-name:var(--font-serif)] italic text-[1.125rem] leading-[1.4] text-[color:var(--color-fg-muted)]">
                {s.tagline}
              </p>
            </div>

            <div class="space-y-8">
              <p class="text-[1.0625rem] leading-[1.7] text-[color:var(--color-fg)] max-w-[60ch]">
                {s.summary}
              </p>

              <div>
                <div class="mono-label mb-4">Deliverables</div>
                <ul class="border-t border-[color:var(--color-hairline)]">
                  {s.deliverables.map((d) => (
                    <li class="flex items-start gap-4 py-4 border-b border-[color:var(--color-hairline)]">
                      <span class="shrink-0 pt-1 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                      <span class="leading-[1.6]">{d}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <!-- =========================================================
       PROCESS
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="mono-label">03 · How the engagement runs</div>
      <h2 class="mt-5"
          style="font-size: var(--text-display); line-height: 1.05;">
        Audit. Build. Write. Monitor.
      </h2>

      <div class="mt-16 grid gap-12 md:grid-cols-2 lg:grid-cols-4">
        {process.map((step) => (
          <div>
            <div class="font-[family-name:var(--font-sans)] text-[0.8125rem] uppercase tracking-[0.18em] text-[color:var(--color-accent)] font-semibold">
              Step {step.num}
            </div>
            <h3 class="mt-4 font-[family-name:var(--font-serif)] text-[1.75rem] leading-[1.1] tracking-[-0.01em]">
              {step.title}
            </h3>
            <p class="mt-4 text-[color:var(--color-fg-muted)] leading-[1.65]">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FINAL CTA
       ========================================================= -->
  <section>
    <Container class="py-24 md:py-36 text-center">
      <p class="font-[family-name:var(--font-serif)] italic text-balance mx-auto max-w-3xl"
         style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.2;">
        Ready to become the answer in your category?
      </p>
      <div class="mt-10 flex justify-center flex-wrap gap-4">
        <a href="/contact" class="btn btn--primary">
          <span>Start a project</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/" class="btn">
          <span>Back to home</span>
        </a>
      </div>
    </Container>
  </section>
</Base>
