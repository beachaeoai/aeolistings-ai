---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import { site } from '../../lib/site';
import {
  computeTotals,
  defaultIncluded,
  formatUSD,
  dateFmt,
  dateFmtCompact,
  type QuoteLineItem,
} from '../../lib/quote';

export async function getStaticPaths() {
  const quotes = await getCollection('quotes');
  return quotes.map((q) => ({
    params: { slug: q.id },
    props: { quote: q },
  }));
}

interface Props {
  quote: CollectionEntry<'quotes'>;
}

const { quote } = Astro.props;
const { Content } = await render(quote);
const data = quote.data;

const totals = computeTotals(data.oneTime, data.recurring, data.oneTimeDiscount);

// Pre-compute display strings the JS will keep in sync as toggles change.
const initialOneTimeSubtotal = formatUSD(totals.oneTimeSubtotal);
const initialOneTimeTotal = formatUSD(totals.oneTimeTotal);
const initialRecurringTotal = `${formatUSD(totals.recurringSubtotal)}/mo`;

// Render a single line-item row. Used for both upfront and recurring lists.
// Defined inline so we don't need a separate component file for one usage.
function rowProps(item: QuoteLineItem, section: 'one-time' | 'recurring') {
  return {
    'data-line-item': '',
    'data-item-id': item.id,
    'data-section': section,
    'data-price': String(item.price),
    'data-toggle-group': item.toggleGroup ?? '',
    'data-included': defaultIncluded(item) ? '1' : '0',
  };
}
---
<Base
  title={`Quote — ${data.client.business}`}
  description={`Proposal prepared for ${data.client.business} by ${data.preparedBy}.`}
  path={`/quote/${quote.id}`}
  noindex={!data.indexable}
>
  <article id="quote-root"
           data-discount-percent={data.oneTimeDiscount?.percent != null ? String(data.oneTimeDiscount.percent) : ''}
           data-discount-amount={data.oneTimeDiscount?.amount != null ? String(data.oneTimeDiscount.amount) : ''}>
    <!-- =========================================================
         HEADER — quote ID, business name, live totals strip
         ========================================================= -->
    <section class="border-b border-[color:var(--color-hairline)] bg-[color:var(--color-bg-2)]">
      <Container class="py-10 md:py-14">
        <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-start md:items-end">
          <div>
            <div class="mono-label flex flex-wrap items-center gap-3">
              <span>Proposal</span>
              <span aria-hidden="true">·</span>
              <span class="tabular-nums">{data.quoteId}</span>
              <span aria-hidden="true">·</span>
              <span>{site.name}</span>
            </div>
            <h1 class="mt-5 font-[family-name:var(--font-serif)] leading-[1.05] tracking-[-0.01em]"
                style="font-size: var(--text-h1);">
              {data.client.business}
            </h1>
            <div class="mt-3 text-[0.95rem] text-[color:var(--color-fg-muted)] flex flex-wrap gap-x-3">
              {data.client.contact && <span>Prepared for {data.client.contact}</span>}
              {data.client.contact && data.client.domain && <span aria-hidden="true">·</span>}
              {data.client.domain && (
                <a href={`https://${data.client.domain}`} target="_blank" rel="noopener noreferrer"
                   class="link-slide text-[color:var(--color-fg)]">{data.client.domain}</a>
              )}
            </div>
          </div>

          <!-- LIVE TOTALS — updated by JS when toggles change -->
          <div class="flex flex-wrap gap-x-10 gap-y-4 md:justify-end">
            <div>
              <div class="mono-label">One-time</div>
              <div class="mt-1 font-[family-name:var(--font-serif)] tabular-nums leading-none"
                   style="font-size: clamp(1.75rem, 3vw, 2.25rem);"
                   data-total="oneTimeTotal">{initialOneTimeTotal}</div>
            </div>
            <div>
              <div class="mono-label">Monthly</div>
              <div class="mt-1 font-[family-name:var(--font-serif)] tabular-nums leading-none"
                   style="font-size: clamp(1.75rem, 3vw, 2.25rem);"
                   data-total="recurringTotal">{initialRecurringTotal}</div>
            </div>
          </div>
        </div>

        <!-- METADATA STRIP -->
        <dl class="mt-8 pt-6 border-t border-[color:var(--color-hairline)] grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-4 text-[0.9rem]">
          <div>
            <dt class="mono-label">Prepared by</dt>
            <dd class="mt-1">{data.preparedBy}</dd>
          </div>
          <div>
            <dt class="mono-label">Issued</dt>
            <dd class="mt-1 tabular-nums">
              <time datetime={data.preparedOn.toISOString()}>{dateFmt.format(data.preparedOn)}</time>
            </dd>
          </div>
          <div>
            <dt class="mono-label">Valid until</dt>
            <dd class="mt-1 tabular-nums">
              <time datetime={data.validUntil.toISOString()}>{dateFmt.format(data.validUntil)}</time>
            </dd>
          </div>
          <div>
            <dt class="mono-label">Reference</dt>
            <dd class="mt-1 tabular-nums">{data.quoteId}</dd>
          </div>
        </dl>
      </Container>
    </section>

    <!-- =========================================================
         INTRO — summary + scope notes (tight)
         ========================================================= -->
    <section class="border-b border-[color:var(--color-hairline)]">
      <Container class="py-12 md:py-16">
        <div class="grid md:grid-cols-[1fr_2fr] gap-8 md:gap-16">
          <div>
            <div class="mono-label">01 · The work</div>
          </div>
          <div class="max-w-[60ch] space-y-5 text-[1rem] leading-[1.65]">
            {data.summary && <p>{data.summary}</p>}
            <div class="quote-prose">
              <Content />
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- =========================================================
         UPFRONT — collapsible line items
         ========================================================= -->
    {data.oneTime.length > 0 && (
      <section class="border-b border-[color:var(--color-hairline)]">
        <Container class="py-12 md:py-16">
          <div class="flex items-baseline justify-between gap-6 flex-wrap">
            <div>
              <div class="mono-label">02 · Upfront</div>
              <h2 class="mt-3 font-[family-name:var(--font-serif)] leading-[1.05]"
                  style="font-size: var(--text-h2);">One-time investment.</h2>
            </div>
            <p class="text-sm text-[color:var(--color-fg-muted)] max-w-[40ch]">
              Click any line to expand. Use the checkbox to add or remove a service.
            </p>
          </div>

          <ul class="mt-10 border-t border-[color:var(--color-hairline)]">
            {data.oneTime.map((item) => (
              <li class="border-b border-[color:var(--color-hairline)]">
                <details class="line-item group" {...rowProps(item, 'one-time')}>
                  <summary class="line-summary list-none cursor-pointer py-4 md:py-5 grid grid-cols-[auto_1fr_auto_auto] items-center gap-3 md:gap-6">
                    <!-- Toggle column — togglable items get a checkbox; required items get an accent dot -->
                    <span class="line-toggle inline-flex items-center justify-center w-[1.25rem]">
                      {item.togglable ? (
                        <label class="inline-flex items-center cursor-pointer">
                          <input
                            type="checkbox"
                            data-toggle-check
                            checked={item.defaultIncluded}
                            class="h-[1.125rem] w-[1.125rem] accent-[color:var(--color-accent)] cursor-pointer"
                            aria-label={`Include ${item.name}`}
                          />
                        </label>
                      ) : (
                        <>
                          <span class="block w-[0.6rem] h-[0.6rem] rounded-full bg-[color:var(--color-accent)]" aria-hidden="true"></span>
                          <span class="sr-only">Included in scope</span>
                        </>
                      )}
                    </span>
                    <!-- Name -->
                    <span class="font-[family-name:var(--font-serif)] text-[1.125rem] md:text-[1.25rem] leading-[1.3]" data-line-name>{item.name}</span>
                    <!-- Price -->
                    <span class="line-price font-[family-name:var(--font-serif)] tabular-nums text-[1.25rem] md:text-[1.5rem]">{formatUSD(item.price)}</span>
                    <!-- Chevron -->
                    <span class="line-chevron text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)] text-[0.85rem] uppercase tracking-[0.14em]" aria-hidden="true">+</span>
                  </summary>
                  <div class="line-body pl-[2rem] md:pl-[2.5rem] pr-2 pb-6 max-w-[68ch] text-[0.95rem] leading-[1.65] text-[color:var(--color-fg-muted)]">
                    <p>{item.description}</p>
                    {item.note && (
                      <p class="mt-2 italic font-[family-name:var(--font-serif)] text-[color:var(--color-fg-muted)]">{item.note}</p>
                    )}
                  </div>
                </details>
              </li>
            ))}
          </ul>

          <!-- One-time totals -->
          <div class="mt-8 ml-auto md:max-w-md grid grid-cols-[1fr_auto] gap-x-8 gap-y-2 text-[0.95rem] tabular-nums">
            <div class="text-[color:var(--color-fg-muted)]">Subtotal</div>
            <div class="text-right" data-total="oneTimeSubtotal">{initialOneTimeSubtotal}</div>

            {data.oneTimeDiscount && (
              <>
                <div class="text-[color:var(--color-accent)]">{data.oneTimeDiscount.label}</div>
                <div class="text-right text-[color:var(--color-accent)]" data-total="oneTimeDiscount">−{formatUSD(totals.oneTimeDiscount)}</div>
              </>
            )}

            <div class="col-span-2 mt-2 pt-3 border-t border-[color:var(--color-fg)] grid grid-cols-[1fr_auto] gap-x-8 items-baseline">
              <div class="font-[family-name:var(--font-sans)] uppercase tracking-[0.14em] text-[0.8rem] font-semibold">One-time total</div>
              <div class="text-right font-[family-name:var(--font-serif)] tabular-nums" style="font-size: clamp(1.5rem, 2.5vw, 1.875rem);" data-total="oneTimeTotal">{initialOneTimeTotal}</div>
            </div>
          </div>
        </Container>
      </section>
    )}

    <!-- =========================================================
         RECURRING — collapsible line items
         ========================================================= -->
    {data.recurring.length > 0 && (
      <section class="border-b border-[color:var(--color-hairline)]">
        <Container class="py-12 md:py-16">
          <div>
            <div class="mono-label">03 · Recurring</div>
            <h2 class="mt-3 font-[family-name:var(--font-serif)] leading-[1.05]"
                style="font-size: var(--text-h2);">Monthly services.</h2>
          </div>

          <ul class="mt-10 border-t border-[color:var(--color-hairline)]">
            {data.recurring.map((item) => (
              <li class="border-b border-[color:var(--color-hairline)]">
                <details class="line-item group" {...rowProps(item, 'recurring')}>
                  <summary class="line-summary list-none cursor-pointer py-5 grid grid-cols-[auto_1fr_auto_auto] items-center gap-4 md:gap-6">
                    <span class="line-toggle inline-flex items-center justify-center min-w-[1.5rem]">
                      {item.togglable ? (
                        <label class="inline-flex items-center cursor-pointer">
                          <input
                            type="checkbox"
                            data-toggle-check
                            checked={item.defaultIncluded}
                            class="h-[1.125rem] w-[1.125rem] accent-[color:var(--color-accent)] cursor-pointer"
                            aria-label={`Include ${item.name}`}
                          />
                        </label>
                      ) : (
                        <span class="mono-label text-[color:var(--color-accent)] text-[0.7rem]">Included</span>
                      )}
                    </span>
                    <span class="font-[family-name:var(--font-serif)] text-[1.125rem] md:text-[1.25rem] leading-[1.3]" data-line-name>{item.name}</span>
                    <span class="line-price font-[family-name:var(--font-serif)] tabular-nums text-[1.25rem] md:text-[1.5rem] whitespace-nowrap">
                      {formatUSD(item.price)}<span class="text-[0.85rem] text-[color:var(--color-fg-muted)]">/mo</span>
                    </span>
                    <span class="line-chevron text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)] text-[0.85rem] uppercase tracking-[0.14em]" aria-hidden="true">+</span>
                  </summary>
                  <div class="line-body pl-[2rem] md:pl-[2.5rem] pr-2 pb-6 max-w-[68ch] text-[0.95rem] leading-[1.65] text-[color:var(--color-fg-muted)]">
                    <p>{item.description}</p>
                    {item.note && (
                      <p class="mt-2 italic font-[family-name:var(--font-serif)] text-[color:var(--color-fg-muted)]">{item.note}</p>
                    )}
                  </div>
                </details>
              </li>
            ))}
          </ul>

          <div class="mt-8 ml-auto md:max-w-md grid grid-cols-[1fr_auto] gap-x-8 items-baseline">
            <div class="font-[family-name:var(--font-sans)] uppercase tracking-[0.14em] text-[0.8rem] font-semibold">Monthly total</div>
            <div class="text-right font-[family-name:var(--font-serif)] tabular-nums" style="font-size: clamp(1.5rem, 2.5vw, 1.875rem);" data-total="recurringTotal">{initialRecurringTotal}</div>
          </div>
        </Container>
      </section>
    )}

    <!-- =========================================================
         SELECTION SUMMARY — current scope recap before accept
         ========================================================= -->
    <section class="border-b border-[color:var(--color-hairline)] bg-[color:var(--color-bg-2)]">
      <Container class="py-12 md:py-16">
        <div class="grid md:grid-cols-[1fr_auto] gap-8 md:gap-16 items-start">
          <div>
            <div class="mono-label">04 · Your scope</div>
            <h2 class="mt-3 font-[family-name:var(--font-serif)] leading-[1.05]"
                style="font-size: var(--text-h2);">What you've selected.</h2>
            <ul id="selection-list" class="mt-6 space-y-2 text-[0.95rem] leading-[1.55]"></ul>
            <p class="mt-6 text-sm text-[color:var(--color-fg-muted)] italic font-[family-name:var(--font-serif)]">
              Toggle services above to adjust the scope.
            </p>
          </div>
          <div class="md:text-right md:min-w-[16rem]">
            <div class="mono-label">One-time total</div>
            <div class="font-[family-name:var(--font-serif)] tabular-nums leading-none mt-1" style="font-size: clamp(2rem, 4vw, 2.75rem);" data-total="oneTimeTotal">{initialOneTimeTotal}</div>
            <div class="mono-label mt-6">Monthly total</div>
            <div class="font-[family-name:var(--font-serif)] tabular-nums leading-none mt-1" style="font-size: clamp(2rem, 4vw, 2.75rem);" data-total="recurringTotal">{initialRecurringTotal}</div>
          </div>
        </div>
      </Container>
    </section>

    <!-- =========================================================
         TERMS — collapsible
         ========================================================= -->
    {data.terms.length > 0 && (
      <section class="border-b border-[color:var(--color-hairline)]">
        <Container class="py-10 md:py-12">
          <details class="terms-collapsible group">
            <summary class="list-none cursor-pointer flex items-baseline justify-between gap-4">
              <div>
                <div class="mono-label">05 · Terms</div>
                <h2 class="mt-2 font-[family-name:var(--font-serif)] leading-[1.05]"
                    style="font-size: var(--text-h2);">The deal.</h2>
              </div>
              <span class="line-chevron text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)] text-[0.85rem] uppercase tracking-[0.14em]" aria-hidden="true">View</span>
            </summary>
            <ul class="mt-6 border-t border-[color:var(--color-hairline)]">
              {data.terms.map((t) => (
                <li class="flex items-start gap-4 py-4 border-b border-[color:var(--color-hairline)] leading-[1.55] text-[0.95rem]">
                  <span class="shrink-0 pt-1 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>
          </details>
        </Container>
      </section>
    )}

    <!-- =========================================================
         ACCEPT BLOCK
         ========================================================= -->
    <section id="accept" class="border-b border-[color:var(--color-hairline)]">
      <Container class="py-16 md:py-20">
        <div class="grid md:grid-cols-[1fr_2fr] gap-10 md:gap-16">
          <div>
            <div class="mono-label">06 · Accept</div>
            <h2 class="mt-3 font-[family-name:var(--font-serif)] leading-[1.05]"
                style="font-size: var(--text-display);">Accept this<br/>quote.</h2>
            <p class="mt-5 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-sm text-[0.95rem]">
              Type your name to e-sign. We'll confirm by email within one business day.
            </p>
          </div>

          <div>
            <form id="accept-form" class="space-y-5" novalidate>
              <input type="hidden" name="quoteId" value={data.quoteId} />
              <input type="hidden" name="slug" value={quote.id} />

              <div>
                <label for="accept-name" class="mono-label block">Your full name *</label>
                <input
                  id="accept-name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  placeholder="Full legal name — acts as your e-signature"
                  class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
                />
              </div>

              <div>
                <label for="accept-email" class="mono-label block">Email *</label>
                <input
                  id="accept-email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  placeholder="Where the contract and invoice should land"
                  class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
                />
              </div>

              <div>
                <label for="accept-note" class="mono-label block">Anything to flag (optional)</label>
                <textarea
                  id="accept-note"
                  name="note"
                  rows="3"
                  placeholder="Scope changes, timing notes, or questions for the kickoff call."
                  class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none resize-y rounded-[2px]"
                ></textarea>
              </div>

              <p class="text-sm text-[color:var(--color-fg-muted)] leading-[1.6]">
                By typing your name and clicking <strong>Accept</strong> you agree to the
                scope shown above. Upfront work is invoiced 50% on acceptance, 50% on launch.
              </p>

              <div
                id="accept-error"
                role="alert"
                aria-live="polite"
                class="hidden border border-[color:var(--color-accent)] px-4 py-3 text-sm text-[color:var(--color-accent)] font-[family-name:var(--font-sans)] rounded-[2px]"
              ></div>

              <div class="pt-1 flex flex-wrap items-center gap-4">
                <button id="accept-submit" type="submit" class="btn btn--primary">
                  <span class="accept-submit-label">Accept this quote</span>
                  <span aria-hidden="true" class="accept-submit-arrow">→</span>
                </button>
                <span class="font-[family-name:var(--font-sans)] text-xs text-[color:var(--color-fg-muted)]">
                  Or reply to the email this link came from to request changes.
                </span>
              </div>

              <noscript>
                <p class="mt-4 text-sm text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)]">
                  JavaScript is required to accept here. Email
                  <a href={`mailto:${site.email}`} class="text-[color:var(--color-accent)] underline">{site.email}</a>
                  with your acceptance instead.
                </p>
              </noscript>
            </form>

            <div
              id="accept-success"
              class="hidden border border-[color:var(--color-hairline)] bg-[color:var(--color-bg-2)] p-8 rounded-[2px]"
              role="status"
              aria-live="polite"
            >
              <div class="mono-label text-[color:var(--color-accent)]">Accepted</div>
              <h3 class="mt-3 font-[family-name:var(--font-serif)] text-[1.5rem] leading-[1.15]">
                Thank you. We'll be in touch.
              </h3>
              <p class="mt-4 text-[color:var(--color-fg-muted)] leading-[1.65] text-[0.95rem]">
                You'll get a confirmation email at the address above with the contract,
                the first invoice, and a link to book the kickoff call.
              </p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- =========================================================
         QUOTE FOOTER — total recap, dates, ID
         ========================================================= -->
    <section class="bg-[color:var(--color-bg-3)] border-b border-[color:var(--color-hairline)]">
      <Container class="py-10 md:py-12">
        <div class="grid md:grid-cols-3 gap-8 md:gap-12 text-[0.875rem]">
          <div>
            <div class="mono-label">Quote</div>
            <div class="mt-2 font-[family-name:var(--font-serif)] text-[1.25rem] leading-[1.2]">
              {data.client.business}
            </div>
            <div class="mt-1 text-[color:var(--color-fg-muted)]">
              Reference {data.quoteId}
            </div>
          </div>
          <div>
            <div class="mono-label">Final totals</div>
            <div class="mt-2 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 tabular-nums">
              <span class="text-[color:var(--color-fg-muted)]">Upfront</span>
              <span class="text-right" data-total="oneTimeTotal">{initialOneTimeTotal}</span>
              <span class="text-[color:var(--color-fg-muted)]">Monthly</span>
              <span class="text-right" data-total="recurringTotal">{initialRecurringTotal}</span>
            </div>
          </div>
          <div>
            <div class="mono-label">Validity</div>
            <div class="mt-2 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 tabular-nums text-[color:var(--color-fg-muted)]">
              <span>Issued</span>
              <span class="text-right">{dateFmtCompact.format(data.preparedOn)}</span>
              <span>Expires</span>
              <span class="text-right">{dateFmtCompact.format(data.validUntil)}</span>
            </div>
            <div class="mt-3 text-[color:var(--color-fg-muted)]">
              Prepared by {data.preparedBy} · <a href={`mailto:${site.email}`} class="link-slide text-[color:var(--color-fg)]">{site.email}</a>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </article>

  <!-- =========================================================
       STYLES — line item collapse animations + excluded state
       ========================================================= -->
  <style is:global>
    .line-item summary::-webkit-details-marker { display: none; }
    .line-item summary { user-select: none; }
    .line-item[open] .line-chevron { transform: rotate(45deg); }
    .line-chevron {
      display: inline-block;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
      min-width: 1.25rem;
      text-align: center;
    }
    .line-item[data-included="0"] .line-summary > *:not(.line-toggle):not(.line-chevron) {
      opacity: 0.45;
    }
    .line-item[data-included="0"] .line-price {
      text-decoration: line-through;
    }
    .line-item[data-included="0"] .line-body {
      opacity: 0.55;
    }
    .terms-collapsible summary::-webkit-details-marker { display: none; }
    .terms-collapsible[open] .line-chevron { transform: rotate(45deg); }

    /* Quote-page markdown body — denser than blog post body. */
    .quote-prose p { margin: 0 0 0.75em; }
    .quote-prose p:last-child { margin-bottom: 0; }
    .quote-prose strong { font-weight: 600; }
  </style>

  <!-- =========================================================
       CLIENT-SIDE: view tracking + toggle handler + accept
       ========================================================= -->
  <script is:inline define:vars={{
    slug: quote.id,
    quoteId: data.quoteId,
    business: data.client.business,
    discountPercent: data.oneTimeDiscount?.percent ?? null,
    discountFixed: data.oneTimeDiscount?.amount ?? null,
  }}>
    (() => {
      const ENDPOINT = '/api/quote-event';
      const root = document.getElementById('quote-root');
      if (!root) return;

      // Resolve discount in dollars given a subtotal.
      // Percent wins if both are set; matches the page-level helper.
      function computeDiscount(subtotal) {
        if (typeof discountPercent === 'number') {
          return Math.round((subtotal * discountPercent) / 100);
        }
        if (typeof discountFixed === 'number') {
          return discountFixed;
        }
        return 0;
      }

      // ── Fire-and-forget view event on page load ──────────────────
      const sendView = () => {
        const payload = JSON.stringify({
          event: 'view',
          slug,
          quoteId,
          business,
          referrer: document.referrer || '',
          ts: Date.now(),
        });
        try {
          if (navigator.sendBeacon) {
            navigator.sendBeacon(ENDPOINT, new Blob([payload], { type: 'application/json' }));
            return;
          }
        } catch { /* fall through to fetch */ }
        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: payload,
          keepalive: true,
        }).catch(() => { /* tracking is best-effort */ });
      };
      sendView();

      // ── Toggle group handling + live totals ──────────────────────
      const usd = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0,
      });

      function setItemIncluded(itemEl, included) {
        itemEl.dataset.included = included ? '1' : '0';
        const cb = itemEl.querySelector('input[data-toggle-check]');
        if (cb) cb.checked = included;
      }

      function recompute() {
        let oneTimeSubtotal = 0;
        let recurringTotal = 0;
        const items = root.querySelectorAll('[data-line-item]');
        const selected = [];

        items.forEach((item) => {
          if (item.dataset.included !== '1') return;
          const price = Number(item.dataset.price || 0);
          if (item.dataset.section === 'one-time') oneTimeSubtotal += price;
          else if (item.dataset.section === 'recurring') recurringTotal += price;

          const nameEl = item.querySelector('[data-line-name]');
          if (nameEl) {
            selected.push({
              id: item.dataset.itemId,
              name: nameEl.textContent.trim(),
              price,
              section: item.dataset.section,
            });
          }
        });

        const oneTimeDiscount = computeDiscount(oneTimeSubtotal);
        const oneTimeTotal = oneTimeSubtotal - oneTimeDiscount;

        const updates = {
          oneTimeSubtotal,
          oneTimeDiscount,
          oneTimeTotal,
          recurringTotal,
        };
        for (const [key, value] of Object.entries(updates)) {
          const isMonthly = key === 'recurringTotal';
          const isDiscount = key === 'oneTimeDiscount';
          let formatted;
          if (isMonthly) formatted = `${usd.format(value)}/mo`;
          else if (isDiscount) formatted = `−${usd.format(value)}`;
          else formatted = usd.format(value);
          root.querySelectorAll(`[data-total="${key}"]`).forEach((el) => {
            el.textContent = formatted;
          });
        }

        // Selection list
        const list = document.getElementById('selection-list');
        if (list) {
          if (selected.length === 0) {
            list.innerHTML = '<li class="text-[color:var(--color-fg-muted)] italic font-[family-name:var(--font-serif)]">Nothing selected — toggle a service above to begin.</li>';
          } else {
            list.innerHTML = selected.map((s) => {
              const priceLabel = s.section === 'recurring'
                ? `${usd.format(s.price)}/mo`
                : usd.format(s.price);
              return `<li class="flex items-start gap-3"><span class="shrink-0 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)] mt-1">·</span><span class="flex-1">${escapeHtml(s.name)}</span><span class="font-[family-name:var(--font-serif)] tabular-nums whitespace-nowrap">${priceLabel}</span></li>`;
            }).join('');
          }
        }

        return { selected, oneTimeSubtotal, oneTimeDiscount, oneTimeTotal, recurringTotal };
      }

      function escapeHtml(s) {
        return String(s)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      }

      // Wire up checkboxes
      root.querySelectorAll('input[data-toggle-check]').forEach((cb) => {
        // Don't toggle the <details> when clicking the checkbox.
        cb.addEventListener('click', (e) => e.stopPropagation());
        cb.addEventListener('change', () => {
          const item = cb.closest('[data-line-item]');
          if (!item) return;
          const group = item.dataset.toggleGroup;
          const included = cb.checked;
          if (group) {
            root.querySelectorAll(`[data-line-item][data-toggle-group="${CSS.escape(group)}"]`).forEach((groupItem) => {
              setItemIncluded(groupItem, included);
            });
          } else {
            setItemIncluded(item, included);
          }
          recompute();
        });
      });

      // Initial render of the selection list
      recompute();

      // ── Accept form ──────────────────────────────────────────────
      const form = document.getElementById('accept-form');
      const submitBtn = document.getElementById('accept-submit');
      const errorBox = document.getElementById('accept-error');
      const successBox = document.getElementById('accept-success');
      if (!form || !submitBtn || !errorBox || !successBox) return;

      const labelEl = submitBtn.querySelector('.accept-submit-label');
      const arrowEl = submitBtn.querySelector('.accept-submit-arrow');
      const originalLabel = labelEl ? labelEl.textContent : 'Accept this quote';

      const setBusy = (busy) => {
        submitBtn.disabled = busy;
        if (labelEl) labelEl.textContent = busy ? 'Accepting…' : originalLabel;
        if (arrowEl) arrowEl.style.opacity = busy ? '0.4' : '1';
      };

      const showError = (msg) => {
        errorBox.textContent = msg;
        errorBox.classList.remove('hidden');
      };

      const ERROR_COPY = {
        missing_fields: 'Please fill in your name and email.',
        invalid_email: 'That email looks off — could you double-check?',
        empty_scope: 'Add at least one service before accepting.',
        send_failed: "We couldn't record that just now. Email us directly and we'll catch it from there.",
        network: "We couldn't reach the server. Check your connection and try again, or email us directly.",
        unknown: "Something went wrong. Email us directly and we'll handle it from there.",
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorBox.classList.add('hidden');

        if (!form.reportValidity()) return;

        const fd = new FormData(form);
        const { selected, oneTimeSubtotal, oneTimeDiscount, oneTimeTotal, recurringTotal } = recompute();

        if (selected.length === 0) {
          showError(ERROR_COPY.empty_scope);
          return;
        }

        const payload = {
          event: 'accept',
          slug,
          quoteId,
          business,
          name: String(fd.get('name') || '').trim(),
          email: String(fd.get('email') || '').trim(),
          note: String(fd.get('note') || '').trim(),
          selectedItems: selected,
          totals: {
            oneTimeSubtotal,
            oneTimeDiscount,
            oneTimeTotal,
            recurringTotal,
          },
          ts: Date.now(),
        };

        setBusy(true);
        let res;
        try {
          res = await fetch(ENDPOINT, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
        } catch {
          setBusy(false);
          showError(ERROR_COPY.network);
          return;
        }

        let data = null;
        try { data = await res.json(); } catch { /* fall through */ }

        if (res.ok && data && data.ok) {
          form.style.display = 'none';
          successBox.classList.remove('hidden');
          successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }

        setBusy(false);
        const code = data && data.error ? data.error : 'unknown';
        showError(ERROR_COPY[code] || ERROR_COPY.unknown);
      });
    })();
  </script>
</Base>
