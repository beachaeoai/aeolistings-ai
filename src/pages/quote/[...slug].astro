---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import { site } from '../../lib/site';
import { computeTotals, formatUSD, dateFmt } from '../../lib/quote';

export async function getStaticPaths() {
  const quotes = await getCollection('quotes');
  return quotes.map((q) => ({
    params: { slug: q.id },
    props: { quote: q },
  }));
}

interface Props {
  quote: CollectionEntry<'quotes'>;
}

const { quote } = Astro.props;
const { Content } = await render(quote);
const data = quote.data;

const totals = computeTotals(data.oneTime, data.recurring, data.oneTimeDiscount);

const hasOneTime = data.oneTime.length > 0;
const hasRecurringRequired = data.recurring.some((i) => !i.optional);
const hasRecurringOptional = data.recurring.some((i) => i.optional);
---
<Base
  title={`Quote — ${data.client.business}`}
  description={`Proposal prepared for ${data.client.business} by ${data.preparedBy}.`}
  path={`/quote/${quote.id}`}
  noindex={!data.indexable}
>
  <!-- =========================================================
       HERO — client, quote ID, dates
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-16 md:py-24">
      <div class="mono-label flex flex-wrap items-center gap-3">
        <span>Proposal · {data.quoteId}</span>
        <span aria-hidden="true">·</span>
        <span>{site.name}</span>
      </div>

      <h1 class="mt-8 text-balance max-w-[28ch]"
          style="font-family: var(--font-serif); font-size: var(--text-display); line-height: 1.02;">
        Prepared for {data.client.business}.
      </h1>

      {data.summary && (
        <p class="mt-8 max-w-2xl text-lg md:text-xl leading-[1.6] text-[color:var(--color-fg-muted)]">
          {data.summary}
        </p>
      )}

      <dl class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-6 border-t border-[color:var(--color-hairline)] pt-8">
        <div>
          <dt class="mono-label">Prepared by</dt>
          <dd class="mt-2 font-[family-name:var(--font-serif)] text-[1.125rem]">{data.preparedBy}</dd>
        </div>
        <div>
          <dt class="mono-label">Issued</dt>
          <dd class="mt-2 font-[family-name:var(--font-serif)] text-[1.125rem] tabular-nums">
            <time datetime={data.preparedOn.toISOString()}>{dateFmt.format(data.preparedOn)}</time>
          </dd>
        </div>
        <div>
          <dt class="mono-label">Valid until</dt>
          <dd class="mt-2 font-[family-name:var(--font-serif)] text-[1.125rem] tabular-nums">
            <time datetime={data.validUntil.toISOString()}>{dateFmt.format(data.validUntil)}</time>
          </dd>
        </div>
        {data.client.contact && (
          <div>
            <dt class="mono-label">Contact</dt>
            <dd class="mt-2 font-[family-name:var(--font-serif)] text-[1.125rem]">{data.client.contact}</dd>
          </div>
        )}
      </dl>
    </Container>
  </section>

  <!-- =========================================================
       SCOPE — markdown body
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-16 md:py-24">
      <div class="mono-label">01 · Scope</div>
      <div class="mt-8 post-body mx-auto">
        <Content />
      </div>
    </Container>
  </section>

  <!-- =========================================================
       ONE-TIME LINE ITEMS
       ========================================================= -->
  {hasOneTime && (
    <section class="border-b border-[color:var(--color-hairline)]">
      <Container class="py-16 md:py-24">
        <div class="mono-label">02 · Upfront</div>
        <h2 class="mt-5"
            style="font-size: var(--text-display); line-height: 1.05;">
          One-time investment.
        </h2>

        <ul class="mt-12 border-t border-[color:var(--color-hairline)]">
          {data.oneTime.map((item) => (
            <li class="grid md:grid-cols-[1fr_auto] gap-4 md:gap-12 py-8 border-b border-[color:var(--color-hairline)]">
              <div class="max-w-[60ch]">
                <div class="font-[family-name:var(--font-serif)] text-[1.5rem] md:text-[1.75rem] leading-[1.2]">
                  {item.name}
                </div>
                <p class="mt-3 text-[1rem] leading-[1.65] text-[color:var(--color-fg-muted)]">
                  {item.description}
                </p>
                {item.note && (
                  <p class="mt-3 text-sm italic text-[color:var(--color-fg-muted)] font-[family-name:var(--font-serif)]">
                    {item.note}
                  </p>
                )}
              </div>
              <div class="md:text-right whitespace-nowrap shrink-0">
                {item.regularPrice && item.regularPrice !== item.price && (
                  <div class="font-[family-name:var(--font-sans)] text-sm text-[color:var(--color-fg-dim)] line-through tabular-nums">
                    {formatUSD(item.regularPrice)}
                  </div>
                )}
                <div class="font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem] tabular-nums">
                  {formatUSD(item.price)}
                </div>
              </div>
            </li>
          ))}
        </ul>

        <!-- Subtotal / discount / total -->
        <div class="mt-10 ml-auto md:max-w-md grid grid-cols-[1fr_auto] gap-x-8 gap-y-3 text-[1rem] tabular-nums">
          <div class="text-[color:var(--color-fg-muted)]">Subtotal</div>
          <div class="text-right">{formatUSD(totals.oneTimeSubtotal)}</div>

          {data.oneTimeDiscount && (
            <>
              <div class="text-[color:var(--color-accent)]">{data.oneTimeDiscount.label}</div>
              <div class="text-right text-[color:var(--color-accent)]">−{formatUSD(totals.oneTimeDiscount)}</div>
            </>
          )}

          <div class="col-span-2 border-t border-[color:var(--color-fg)] mt-2 pt-3 grid grid-cols-[1fr_auto] gap-x-8">
            <div class="font-[family-name:var(--font-sans)] uppercase tracking-[0.14em] text-[0.875rem] font-semibold">
              One-time total
            </div>
            <div class="text-right font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem]">
              {formatUSD(totals.oneTimeTotal)}
            </div>
          </div>
        </div>
      </Container>
    </section>
  )}

  <!-- =========================================================
       RECURRING LINE ITEMS
       ========================================================= -->
  {data.recurring.length > 0 && (
    <section class="border-b border-[color:var(--color-hairline)]">
      <Container class="py-16 md:py-24">
        <div class="mono-label">03 · Recurring</div>
        <h2 class="mt-5"
            style="font-size: var(--text-display); line-height: 1.05;">
          Monthly services.
        </h2>

        <ul class="mt-12 border-t border-[color:var(--color-hairline)]">
          {data.recurring.map((item) => (
            <li class="grid md:grid-cols-[1fr_auto] gap-4 md:gap-12 py-8 border-b border-[color:var(--color-hairline)]">
              <div class="max-w-[60ch]">
                <div class="flex flex-wrap items-baseline gap-3">
                  <span class="font-[family-name:var(--font-serif)] text-[1.5rem] md:text-[1.75rem] leading-[1.2]">
                    {item.name}
                  </span>
                  {item.optional && (
                    <span class="tag tag--accent">Optional add-on</span>
                  )}
                </div>
                <p class="mt-3 text-[1rem] leading-[1.65] text-[color:var(--color-fg-muted)]">
                  {item.description}
                </p>
                {item.note && (
                  <p class="mt-3 text-sm italic text-[color:var(--color-fg-muted)] font-[family-name:var(--font-serif)]">
                    {item.note}
                  </p>
                )}
              </div>
              <div class="md:text-right whitespace-nowrap shrink-0">
                {item.regularPrice && item.regularPrice !== item.price && (
                  <div class="font-[family-name:var(--font-sans)] text-sm text-[color:var(--color-fg-dim)] line-through tabular-nums">
                    {formatUSD(item.regularPrice)}/mo
                  </div>
                )}
                <div class="font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem] tabular-nums">
                  {formatUSD(item.price)}<span class="text-[1rem] text-[color:var(--color-fg-muted)]">/mo</span>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <!-- Recurring totals -->
        <div class="mt-10 ml-auto md:max-w-md grid grid-cols-[1fr_auto] gap-x-8 gap-y-3 text-[1rem] tabular-nums">
          {hasRecurringRequired && (
            <div class="col-span-2 grid grid-cols-[1fr_auto] gap-x-8 border-t border-[color:var(--color-fg)] pt-3">
              <div class="font-[family-name:var(--font-sans)] uppercase tracking-[0.14em] text-[0.875rem] font-semibold">
                Monthly total
              </div>
              <div class="text-right font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem]">
                {formatUSD(totals.recurringSubtotal)}<span class="text-[1rem] text-[color:var(--color-fg-muted)]">/mo</span>
              </div>
            </div>
          )}
          {hasRecurringOptional && (
            <div class="col-span-2 grid grid-cols-[1fr_auto] gap-x-8 pt-1 text-[color:var(--color-fg-muted)]">
              <div>With optional add-ons</div>
              <div class="text-right tabular-nums">
                {formatUSD(totals.recurringSubtotal + totals.recurringOptional)}/mo
              </div>
            </div>
          )}
        </div>
      </Container>
    </section>
  )}

  <!-- =========================================================
       TERMS
       ========================================================= -->
  {data.terms.length > 0 && (
    <section class="border-b border-[color:var(--color-hairline)]">
      <Container class="py-16 md:py-24">
        <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
          <div>
            <div class="mono-label">04 · Terms</div>
            <h2 class="mt-5"
                style="font-size: var(--text-h1); line-height: 1.05;">
              The deal.
            </h2>
            <p class="mt-6 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-sm">
              Plain-English terms. No surprises.
            </p>
          </div>
          <ul class="border-t border-[color:var(--color-hairline)]">
            {data.terms.map((t) => (
              <li class="flex items-start gap-4 py-5 border-b border-[color:var(--color-hairline)] leading-[1.6]">
                <span class="shrink-0 pt-1 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                <span>{t}</span>
              </li>
            ))}
          </ul>
        </div>
      </Container>
    </section>
  )}

  <!-- =========================================================
       ACCEPT BLOCK
       ========================================================= -->
  <section id="accept" class="border-b border-[color:var(--color-hairline)] bg-[color:var(--color-bg-2)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">05 · Accept</div>
          <h2 class="mt-5"
              style="font-size: var(--text-display); line-height: 1.05;">
            Accept this<br/>quote.
          </h2>
          <p class="mt-6 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-sm">
            Type your name to e-sign. We'll confirm by email within one
            business day with the contract, kickoff call invite, and the first invoice.
          </p>
        </div>

        <div>
          <form id="accept-form" class="space-y-6" novalidate>
            <input type="hidden" name="quoteId" value={data.quoteId} />
            <input type="hidden" name="slug" value={quote.id} />

            <div>
              <label for="accept-name" class="mono-label block">Your full name *</label>
              <input
                id="accept-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Full legal name — acts as your e-signature"
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              />
            </div>

            <div>
              <label for="accept-email" class="mono-label block">Email *</label>
              <input
                id="accept-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="Where the contract and invoice should land"
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              />
            </div>

            <div>
              <label for="accept-optional" class="mono-label block">Add the optional AEO retainer?</label>
              <select
                id="accept-optional"
                name="includeOptional"
                class="mt-2 block w-full bg-[color:var(--color-bg)] border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              >
                <option value="no">No — just the upfront work and social management</option>
                <option value="yes">Yes — include the AEO retainer at the discounted rate</option>
              </select>
            </div>

            <div>
              <label for="accept-note" class="mono-label block">Anything to flag (optional)</label>
              <textarea
                id="accept-note"
                name="note"
                rows="3"
                placeholder="Scope changes, timing notes, or questions for the kickoff call."
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none resize-y rounded-[2px]"
              ></textarea>
            </div>

            <p class="text-sm text-[color:var(--color-fg-muted)] leading-[1.6]">
              By typing your name and clicking <strong>Accept</strong> you agree to the
              scope and terms above. The first invoice (50% of the upfront total) follows
              by email; the second 50% is invoiced on launch.
            </p>

            <div
              id="accept-error"
              role="alert"
              aria-live="polite"
              class="hidden border border-[color:var(--color-accent)] px-4 py-3 text-sm text-[color:var(--color-accent)] font-[family-name:var(--font-sans)] rounded-[2px]"
            ></div>

            <div class="pt-2 flex flex-wrap items-center gap-4">
              <button id="accept-submit" type="submit" class="btn btn--primary">
                <span class="accept-submit-label">Accept this quote</span>
                <span aria-hidden="true" class="accept-submit-arrow">→</span>
              </button>
              <span class="font-[family-name:var(--font-sans)] text-xs text-[color:var(--color-fg-muted)]">
                Or reply to the email this link came from to request changes.
              </span>
            </div>

            <noscript>
              <p class="mt-4 text-sm text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)]">
                JavaScript is required to accept here. Email
                <a href={`mailto:${site.email}`} class="text-[color:var(--color-accent)] underline">
                  {site.email}
                </a>
                with your acceptance instead.
              </p>
            </noscript>
          </form>

          <!-- Success state -->
          <div
            id="accept-success"
            class="hidden border border-[color:var(--color-hairline)] bg-[color:var(--color-bg)] p-8 rounded-[2px]"
            role="status"
            aria-live="polite"
          >
            <div class="mono-label text-[color:var(--color-accent)]">Accepted</div>
            <h3 class="mt-3 font-[family-name:var(--font-serif)] text-[1.75rem] leading-[1.15]">
              Thank you. We'll be in touch.
            </h3>
            <p class="mt-4 text-[color:var(--color-fg-muted)] leading-[1.65]">
              You'll get a confirmation email at the address above with the
              contract, the first invoice, and a link to book the kickoff call. If
              it doesn't show up within fifteen minutes, check spam, then email
              <a href={`mailto:${site.email}`} class="link-slide text-[color:var(--color-fg)]">{site.email}</a>.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FOOTER NOTE
       ========================================================= -->
  <section>
    <Container class="py-12 text-center">
      <p class="text-sm text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)]">
        Quote {data.quoteId} · Prepared by {data.preparedBy} · {site.name}
      </p>
    </Container>
  </section>

  <!-- =========================================================
       CLIENT-SIDE: view tracking + accept handler
       ========================================================= -->
  <script is:inline define:vars={{ slug: quote.id, quoteId: data.quoteId, business: data.client.business }}>
    (() => {
      const ENDPOINT = '/api/quote-event';

      // ── Fire-and-forget view event on page load ──────────────────
      const sendView = () => {
        const payload = JSON.stringify({
          event: 'view',
          slug,
          quoteId,
          business,
          referrer: document.referrer || '',
          ts: Date.now(),
        });
        try {
          if (navigator.sendBeacon) {
            navigator.sendBeacon(ENDPOINT, new Blob([payload], { type: 'application/json' }));
            return;
          }
        } catch { /* fall through to fetch */ }
        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: payload,
          keepalive: true,
        }).catch(() => { /* tracking is best-effort */ });
      };
      sendView();

      // ── Accept form ──────────────────────────────────────────────
      const form = document.getElementById('accept-form');
      const submitBtn = document.getElementById('accept-submit');
      const errorBox = document.getElementById('accept-error');
      const successBox = document.getElementById('accept-success');
      if (!form || !submitBtn || !errorBox || !successBox) return;

      const labelEl = submitBtn.querySelector('.accept-submit-label');
      const arrowEl = submitBtn.querySelector('.accept-submit-arrow');
      const originalLabel = labelEl ? labelEl.textContent : 'Accept this quote';

      const setBusy = (busy) => {
        submitBtn.disabled = busy;
        if (labelEl) labelEl.textContent = busy ? 'Accepting…' : originalLabel;
        if (arrowEl) arrowEl.style.opacity = busy ? '0.4' : '1';
      };

      const showError = (msg) => {
        errorBox.textContent = msg;
        errorBox.classList.remove('hidden');
      };

      const ERROR_COPY = {
        missing_fields: 'Please fill in your name and email.',
        invalid_email: 'That email looks off — could you double-check?',
        send_failed: "We couldn't record that just now. Email us directly and we'll catch it from there.",
        network: "We couldn't reach the server. Check your connection and try again, or email us directly.",
        unknown: "Something went wrong. Email us directly and we'll handle it from there.",
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorBox.classList.add('hidden');

        if (!form.reportValidity()) return;

        const fd = new FormData(form);
        const payload = {
          event: 'accept',
          slug,
          quoteId,
          business,
          name: String(fd.get('name') || '').trim(),
          email: String(fd.get('email') || '').trim(),
          includeOptional: fd.get('includeOptional') === 'yes',
          note: String(fd.get('note') || '').trim(),
          ts: Date.now(),
        };

        setBusy(true);
        let res;
        try {
          res = await fetch(ENDPOINT, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
        } catch {
          setBusy(false);
          showError(ERROR_COPY.network);
          return;
        }

        let data = null;
        try { data = await res.json(); } catch { /* fall through */ }

        if (res.ok && data && data.ok) {
          form.style.display = 'none';
          successBox.classList.remove('hidden');
          successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }

        setBusy(false);
        const code = data && data.error ? data.error : 'unknown';
        showError(ERROR_COPY[code] || ERROR_COPY.unknown);
      });
    })();
  </script>
</Base>
