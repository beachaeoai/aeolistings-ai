---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';
import { services as siteServices } from '../lib/services';

// ContactPage schema. The root Organization + ContactPoint are shipped
// site-wide from Base.astro; this just wires the page to that entity.
const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${site.url}/contact#page`,
  url: `${site.url}/contact`,
  name: `Contact — ${site.name}`,
  description:
    'Get in touch with AEO Listings. Email is the fastest path for new projects and existing client requests, including cancellations.',
  isPartOf: { '@id': `${site.url}/#website` },
  about: { '@id': `${site.url}/#org` },
};

const formServiceOptions = [
  ...siteServices.map((s) => s.name),
  'Not sure yet',
];

// Show social rows only when a URL is provided (defaults are empty strings).
const socialRows = (
  [
    { label: 'LinkedIn', href: site.social.linkedin as string },
    { label: 'X', href: site.social.x as string },
    { label: 'GitHub', href: site.social.github as string },
  ] as { label: string; href: string }[]
).filter((row) => row.href.length > 0);
---
<Base
  title="Contact"
  description="Get in touch with AEO Listings. Email is the fastest path for new projects, existing clients, and cancellations."
  path="/contact"
  schema={[contactPageSchema]}
>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-32">
      <div class="mono-label">Contact · The agency</div>

      <h1 class="mt-8 text-balance"
          style="font-family: var(--font-serif); font-size: var(--text-display); line-height: 1.02;">
        Let's talk.
      </h1>

      <p class="mt-8 max-w-2xl text-lg md:text-xl leading-[1.6] text-[color:var(--color-fg-muted)]">
        Email is the fastest path. No forms required — but one's below if you prefer.
        Either way, a real person reads and replies, usually within one business day.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href={`mailto:${site.email}`} class="btn btn--primary">
          <span>Email {site.email}</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="#inquiry" class="btn">
          <span>Use the form</span>
        </a>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       TWO-COLUMN: DIRECT CHANNELS + INQUIRY FORM
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20">
        <!-- LEFT: DIRECT CHANNELS -->
        <div>
          <div class="mono-label">01 · Direct</div>
          <h2 class="mt-5"
              style="font-size: var(--text-display); line-height: 1.05;">
            Reach us<br/>directly.
          </h2>
          <p class="mt-6 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-md">
            One inbox. One human. No ticket queue, no drip campaign.
          </p>

          <dl class="mt-10 border-t border-[color:var(--color-hairline)]">
            <!-- Email row -->
            <div class="grid grid-cols-[auto_1fr] gap-6 py-5 border-b border-[color:var(--color-hairline)]">
              <dt class="mono-label pt-1">Email</dt>
              <dd class="min-w-0">
                <a href={`mailto:${site.email}`} class="link-slide font-[family-name:var(--font-serif)] text-[1.25rem] md:text-[1.5rem] break-all text-[color:var(--color-fg)]">
                  {site.email}
                </a>
                <div class="mt-2 text-sm text-[color:var(--color-fg-muted)]">
                  New projects · current clients · anything else.
                </div>
              </dd>
            </div>

            <!-- Hours row -->
            <div class="grid grid-cols-[auto_1fr] gap-6 py-5 border-b border-[color:var(--color-hairline)]">
              <dt class="mono-label pt-1">Hours</dt>
              <dd class="min-w-0">
                <span class="font-[family-name:var(--font-serif)] text-[1.25rem] md:text-[1.5rem]">Monday – Friday</span>
                <div class="mt-2 text-sm text-[color:var(--color-fg-muted)]">
                  Replies within one business day.
                </div>
              </dd>
            </div>

            <!-- Optional social rows — only render if URL provided -->
            {socialRows.map((row) => (
              <div class="grid grid-cols-[auto_1fr] gap-6 py-5 border-b border-[color:var(--color-hairline)]">
                <dt class="mono-label pt-1">{row.label}</dt>
                <dd class="min-w-0">
                  <a href={row.href} rel="noopener noreferrer" target="_blank" class="link-slide font-[family-name:var(--font-sans)] text-[1rem] md:text-[1.0625rem] text-[color:var(--color-fg)]">
                    {row.href.replace(/^https?:\/\//, '')}
                  </a>
                </dd>
              </div>
            ))}
          </dl>

          <div class="mt-10 flex flex-wrap gap-2">
            <span class="tag">Retainer</span>
            <span class="tag">Cancel by email</span>
            <span class="tag tag--accent">1 business day</span>
          </div>
        </div>

        <!-- RIGHT: INQUIRY FORM -->
        <div id="inquiry">
          <div class="mono-label">02 · Inquiry</div>
          <h2 class="mt-5"
              style="font-size: var(--text-display); line-height: 1.05;">
            Or use<br/>the form.
          </h2>
          <p class="mt-6 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-md">
            Send the basics. We'll reply from a real inbox, not a no-reply.
          </p>

          {/*
            Form submission posts JSON to /api/contact, a Cloudflare Worker
            (workers/contact/) that validates, runs anti-spam checks, and
            sends via Resend. See workers/contact/README.md for deploy.
            If JS is disabled, the noscript fallback below points the user
            at the mailto link in the left column.
          */}
          <form
            id="inquiry-form"
            class="mt-10 space-y-6"
            novalidate
          >
            <!-- Honeypot — hidden from humans, irresistible to bots. -->
            <div aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;">
              <label for="_company">Website (leave blank)</label>
              <input id="_company" name="_company" type="text" tabindex="-1" autocomplete="off" />
            </div>

            <!-- Time-trap — populated by inline script on render. -->
            <input id="_ts" name="_ts" type="hidden" value="" />

            <!-- Name -->
            <div>
              <label for="name" class="mono-label block">Name *</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="mono-label block">Email *</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              />
            </div>

            <!-- Business -->
            <div>
              <label for="business" class="mono-label block">Business name</label>
              <input
                id="business"
                name="business"
                type="text"
                autocomplete="organization"
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              />
            </div>

            <!-- City -->
            <div>
              <label for="city" class="mono-label block">City / service area</label>
              <input
                id="city"
                name="city"
                type="text"
                placeholder="e.g. the primary city or region you serve"
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              />
            </div>

            <!-- Service of interest -->
            <div>
              <label for="service" class="mono-label block">Interested in</label>
              <select
                id="service"
                name="service"
                class="mt-2 block w-full bg-[color:var(--color-bg)] border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] focus:border-[color:var(--color-accent)] focus:outline-none rounded-[2px]"
              >
                {formServiceOptions.map((s) => (
                  <option value={s}>{s}</option>
                ))}
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="mono-label block">Message *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Tell us what you're trying to solve — the question your customers ask that you wish AI answered with your name."
                class="mt-2 block w-full bg-transparent border border-[color:var(--color-hairline-2)] px-3 py-3 font-[family-name:var(--font-sans)] text-[0.9375rem] text-[color:var(--color-fg)] placeholder:text-[color:var(--color-fg-dim)] focus:border-[color:var(--color-accent)] focus:outline-none resize-y rounded-[2px]"
              ></textarea>
            </div>

            <!-- Inline error region -->
            <div
              id="inquiry-error"
              role="alert"
              aria-live="polite"
              class="hidden border border-[color:var(--color-accent)] px-4 py-3 text-sm text-[color:var(--color-accent)] font-[family-name:var(--font-sans)] rounded-[2px]"
            ></div>

            <div class="pt-2 flex flex-wrap items-center gap-4">
              <button id="inquiry-submit" type="submit" class="btn btn--primary">
                <span class="inquiry-submit-label">Send inquiry</span>
                <span aria-hidden="true" class="inquiry-submit-arrow">→</span>
              </button>
              <span class="font-[family-name:var(--font-sans)] text-xs text-[color:var(--color-fg-muted)]">
                Goes to a real inbox — reply within one business day.
              </span>
            </div>

            <noscript>
              <p class="mt-4 text-sm text-[color:var(--color-fg-muted)] font-[family-name:var(--font-sans)]">
                JavaScript is required for the form. Email
                <a href={`mailto:${site.email}`} class="text-[color:var(--color-accent)] underline">
                  {site.email}
                </a>
                directly instead.
              </p>
            </noscript>
          </form>

          <!-- Success state — revealed after a successful submission. -->
          <div
            id="inquiry-success"
            class="hidden mt-10 border border-[color:var(--color-hairline)] bg-[color:var(--color-bg-2)] p-8 rounded-[2px]"
            role="status"
            aria-live="polite"
          >
            <div class="mono-label text-[color:var(--color-accent)]">Sent</div>
            <h3 class="mt-3 font-[family-name:var(--font-serif)] text-[1.75rem] leading-[1.15]">
              Thanks. We'll be in touch.
            </h3>
            <p class="mt-4 text-[color:var(--color-fg-muted)] leading-[1.65]">
              Your message landed in our inbox. A real person will reply from
              <a href={`mailto:${site.email}`} class="link-slide text-[color:var(--color-fg)]">{site.email}</a>
              — usually within one business day.
            </p>
          </div>

          <!-- Inline submission script — vanilla JS, no framework. -->
          <script is:inline>
            (() => {
              const form = document.getElementById('inquiry-form');
              const tsField = document.getElementById('_ts');
              const submitBtn = document.getElementById('inquiry-submit');
              const errorBox = document.getElementById('inquiry-error');
              const successBox = document.getElementById('inquiry-success');
              if (!form || !tsField || !submitBtn || !errorBox || !successBox) return;

              // Stamp the time-trap when the form is wired up (= page rendered).
              tsField.value = String(Date.now());

              const labelEl = submitBtn.querySelector('.inquiry-submit-label');
              const arrowEl = submitBtn.querySelector('.inquiry-submit-arrow');
              const originalLabel = labelEl ? labelEl.textContent : 'Send inquiry';

              const setBusy = (busy) => {
                submitBtn.disabled = busy;
                if (labelEl) labelEl.textContent = busy ? 'Sending…' : originalLabel;
                if (arrowEl) arrowEl.style.opacity = busy ? '0.4' : '1';
              };

              const showError = (msg) => {
                errorBox.textContent = msg;
                errorBox.classList.remove('hidden');
              };

              const clearError = () => {
                errorBox.textContent = '';
                errorBox.classList.add('hidden');
              };

              const ERROR_COPY = {
                missing_fields: 'Please fill in name, email, and message.',
                invalid_email: 'That email address looks off — could you double-check?',
                field_too_long: 'One of those fields is too long. Trim it down a bit?',
                send_failed: "We couldn't deliver that just now. Email us directly and we'll catch it from there.",
                network: "We couldn't reach the server. Check your connection and try again, or email us directly.",
                unknown: "Something went wrong. Email us directly and we'll handle it from there.",
              };

              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                clearError();

                if (!form.reportValidity()) return;

                const fd = new FormData(form);
                const payload = {};
                fd.forEach((value, key) => { payload[key] = value; });
                if (payload._ts) payload._ts = Number(payload._ts);

                setBusy(true);
                let res;
                try {
                  res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify(payload),
                  });
                } catch {
                  setBusy(false);
                  showError(ERROR_COPY.network);
                  return;
                }

                let data = null;
                try { data = await res.json(); } catch { /* fall through */ }

                if (res.ok && data && data.ok) {
                  form.style.display = 'none';
                  successBox.classList.remove('hidden');
                  successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                  return;
                }

                setBusy(false);
                const code = data && data.error ? data.error : 'unknown';
                showError(ERROR_COPY[code] || ERROR_COPY.unknown);
              });
            })();
          </script>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       CANCELLATION BLOCK
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">03 · Cancellation</div>
          <h2 class="mt-5"
              style="font-size: var(--text-h1); line-height: 1.05;">
            One email.<br/>Always.
          </h2>
        </div>
        <blockquote class="pullquote">
          Current clients cancel any active retainer by emailing
          <a href={`mailto:${site.email}`} class="text-[color:var(--color-accent)] underline decoration-[color:var(--color-hairline-2)] underline-offset-4">
            {site.email}
          </a>.
          No forms, no phone tree, no retention calls. We'd rather hear why and fix it —
          but cancellation is always <em>one email away</em>.
        </blockquote>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FINAL CTA
       ========================================================= -->
  <section>
    <Container class="py-20 md:py-28 text-center">
      <p class="font-[family-name:var(--font-serif)] italic text-balance mx-auto max-w-3xl"
         style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.2;">
        Prefer a call? Email us first — we'll find a time.
      </p>
      <div class="mt-10 flex justify-center flex-wrap gap-4">
        <a href={`mailto:${site.email}`} class="btn btn--primary">
          <span>Email us</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </Container>
  </section>
</Base>
