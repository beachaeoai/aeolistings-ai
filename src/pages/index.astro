---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';
import { services } from '../lib/services';
import { faq, homepageFaq } from '../lib/faq';

// FAQPage schema — ships the FULL 10-question set as JSON-LD even though only
// the homepage teaser (3 items) is visually rendered. The schema is prime AEO
// fuel and there is no penalty for the schema being broader than the visible
// FAQ section. The full set is also visually rendered on /faq.
//
// Organization + WebSite are now shipped as the site-wide root @graph from
// Base.astro and are intentionally not duplicated here.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${site.url}/#faq`,
  isPartOf: { '@id': `${site.url}/#website` },
  about: { '@id': `${site.url}/#org` },
  mainEntity: faq.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};
---
<Base
  title="Answer Engine Optimization for home service pros"
  description={site.description}
  path="/"
  schema={[faqSchema]}
>
  <!-- =========================================================
       HERO — leads with the buyer's problem in plain language
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-32 lg:py-40">
      <div class="mono-label">Answer Engine Optimization · Retainer agency</div>

      <h1 class="mt-10 text-balance max-w-[20ch]"
          style="font-family: var(--font-serif); font-size: var(--text-display-xl); line-height: 0.98;">
        When someone asks ChatGPT who to hire, is it recommending
        <em class="italic">you</em>?
      </h1>

      <p class="mt-8 md:mt-10 max-w-2xl text-lg md:text-xl leading-[1.55] text-[color:var(--color-fg-muted)]">
        AI chatbots are replacing Google for local recommendations. We make sure your
        business is the name ChatGPT, Google AI, Perplexity, and Claude say back when a
        prospect asks who to hire.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="/contact" class="btn btn--primary">
          <span>Start a project</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/services" class="btn">
          <span>See how it works</span>
        </a>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       WHAT CHANGED — the argument prospects need to accept
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">01 · What changed</div>
          <h2 class="mt-5 text-balance"
              style="font-size: var(--text-display); line-height: 1.05;">
            The way people find local businesses just changed.
          </h2>
        </div>
        <div class="max-w-[60ch]">
          <p class="text-[1.0625rem] leading-[1.65]">
            For twenty years, your prospect typed a question into Google and scrolled through
            a list of blue links. Today, more of them are asking ChatGPT, Perplexity, or
            Google's AI Overviews — and getting back a single recommendation. Not ten. One.
          </p>
          <blockquote class="pullquote">
            The winners of the next decade won't be the sites that rank. They'll be the
            businesses that get recommended by name.
          </blockquote>
          <p class="text-[1.0625rem] leading-[1.65]">
            AI models don't rank websites the way Google does. They read your business
            information across the web, verify it's consistent, and then decide whether they
            trust you enough to name you in an answer. If the signals aren't there — or your
            competitor's signals are stronger — you don't get mentioned. You don't even know
            the conversation happened.
          </p>
          <p class="text-[1.0625rem] leading-[1.65] mt-6">
            We fix that.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       SERVICES — plain-language offers
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <div class="mono-label">02 · What we do</div>
          <h2 class="mt-5 text-balance"
              style="font-size: var(--text-display); line-height: 1.05;">
            Four services.<br />One outcome: you get recommended.
          </h2>
        </div>
        <a href="/services" class="link-slide font-[family-name:var(--font-sans)] text-[0.8125rem] uppercase tracking-[0.14em] font-medium text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]">
          All services →
        </a>
      </div>

      <div class="mt-14 grid gap-14 md:grid-cols-2 md:gap-x-16 md:gap-y-16">
        {services.map((s) => (
          <article>
            <div class="mono-label">{s.num}</div>
            <h3 class="mt-3 font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem] leading-[1.1] tracking-[-0.01em]">
              <a href={`/services#${s.id}`} class="link-slide text-[color:var(--color-fg)] hover:text-[color:var(--color-accent)]">
                {s.name}
              </a>
            </h3>
            <p class="mt-3 font-[family-name:var(--font-serif)] italic text-[1.0625rem] text-[color:var(--color-fg-muted)]">
              {s.tagline}
            </p>
            <p class="mt-4 text-[1rem] leading-[1.65] text-[color:var(--color-fg)] max-w-[52ch]">
              {s.summary}
            </p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <!-- =========================================================
       WHY NOW — three facts, editorial callout
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="mono-label">03 · Why now</div>
      <div class="mt-10 grid md:grid-cols-3 gap-10 md:gap-0">
        <div class="md:pr-10 md:border-r md:border-[color:var(--color-hairline)]">
          <div class="font-[family-name:var(--font-sans)] text-[0.75rem] uppercase tracking-[0.18em] text-[color:var(--color-accent)] font-semibold">Fact 01</div>
          <p class="mt-4 font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem] leading-[1.15] text-balance">
            ChatGPT alone handles <em class="italic not-[font-style:normal]">over one&nbsp;billion</em> queries a day. Many are local-intent.
          </p>
        </div>
        <div class="md:px-10 md:border-r md:border-[color:var(--color-hairline)]">
          <div class="font-[family-name:var(--font-sans)] text-[0.75rem] uppercase tracking-[0.18em] text-[color:var(--color-accent)] font-semibold">Fact 02</div>
          <p class="mt-4 font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem] leading-[1.15] text-balance">
            AI answers increasingly cite <em class="italic">one</em> business by name. Not ten blue links.
          </p>
        </div>
        <div class="md:pl-10">
          <div class="font-[family-name:var(--font-sans)] text-[0.75rem] uppercase tracking-[0.18em] text-[color:var(--color-accent)] font-semibold">Fact 03</div>
          <p class="mt-4 font-[family-name:var(--font-serif)] text-[1.75rem] md:text-[2rem] leading-[1.15] text-balance">
            Most local businesses are <em class="italic">invisible</em> to AI models today.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FAQ — matches FAQPage JSON-LD above
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">04 · FAQ</div>
          <h2 class="mt-5 text-balance"
              style="font-size: var(--text-display); line-height: 1.05;">
            Questions,<br />answered.
          </h2>
          <p class="mt-6 text-[color:var(--color-fg-muted)] max-w-sm leading-[1.6]">
            Structured Q&amp;A is exactly what AI models retrieve and cite. This page is
            itself a demonstration of what we build for clients.
          </p>
        </div>

        <div class="border-t border-[color:var(--color-hairline)]">
          {homepageFaq.map((item, i) => (
            <details class="group border-b border-[color:var(--color-hairline)]">
              <summary class="list-none cursor-pointer py-6 flex items-start justify-between gap-6 font-[family-name:var(--font-serif)] text-[1.25rem] md:text-[1.5rem] leading-[1.25] tracking-[-0.01em]">
                <span class="flex gap-5 items-baseline">
                  <span class="mono-label shrink-0" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span>{item.question}</span>
                </span>
                <span class="shrink-0 pt-1 font-[family-name:var(--font-sans)] text-[color:var(--color-accent)] transition-transform group-open:rotate-45 text-xl"
                      aria-hidden="true">+</span>
              </summary>
              <div class="pb-6 md:pl-14 pr-2 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-[60ch]">
                {item.answer}
              </div>
            </details>
          ))}
          <div class="pt-8">
            <a href="/faq" class="link-slide font-[family-name:var(--font-sans)] text-[0.8125rem] uppercase tracking-[0.14em] font-medium text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-accent)]">
              All {faq.length} questions →
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FINAL CTA — editorial
       ========================================================= -->
  <section>
    <Container class="py-24 md:py-36 text-center">
      <p class="font-[family-name:var(--font-serif)] italic text-balance mx-auto max-w-3xl"
         style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.2;">
        The answer begins with a conversation.
      </p>
      <div class="mt-10 flex justify-center flex-wrap gap-4">
        <a href="/contact" class="btn btn--primary">
          <span>Start a project</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href={`mailto:${site.email}`} class="btn">
          <span>Email us directly</span>
        </a>
      </div>
    </Container>
  </section>
</Base>
