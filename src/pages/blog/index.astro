---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import { site } from '../../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

// Blog schema — publisher references the root Organization (`#org`)
// shipped site-wide from Base.astro.
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${site.url}/blog#blog`,
  url: `${site.url}/blog`,
  name: `${site.name} — Notes`,
  description: 'Essays and research on Answer Engine Optimization.',
  publisher: { '@id': `${site.url}/#org` },
  inLanguage: 'en-US',
};
---
<Base
  title="Notes"
  description="Essays and research on Answer Engine Optimization — fundamentals, tactics, and measurement."
  path="/blog"
  schema={[blogSchema]}
>
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-16 md:py-24">
      <div class="mono-label">Notes · Essays & research</div>
      <h1 class="mt-8 text-balance max-w-[22ch]"
          style="font-family: var(--font-serif); font-size: var(--text-display); line-height: 1.02;">
        Notes on Answer Engine Optimization.
      </h1>
      <p class="mt-10 max-w-2xl text-lg md:text-xl leading-[1.6] text-[color:var(--color-fg-muted)]">
        Essays, research, and working notes. Publishing irregularly. The best pieces
        will probably be the ones the answer engines end up citing themselves.
      </p>
    </Container>
  </section>

  <section>
    <Container class="py-12 md:py-16">
      {posts.length === 0 ? (
        <p class="text-[color:var(--color-fg-muted)] font-[family-name:var(--font-mono)] text-sm">
          [ No posts yet. First piece coming soon. ]
        </p>
      ) : (
        <ul class="border-t border-[color:var(--color-hairline)]">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group grid md:grid-cols-[auto_1fr_auto] items-baseline gap-4 md:gap-8 py-8 md:py-10 border-b border-[color:var(--color-hairline)] transition-colors hover:bg-[color:var(--color-bg-2)] px-2 -mx-2"
              >
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="mono-label tabular-nums shrink-0"
                >
                  {fmt.format(post.data.pubDate)}
                </time>
                <div>
                  <h2 class="text-xl md:text-2xl font-medium tracking-tight leading-snug group-hover:text-[color:var(--color-accent)] transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-[color:var(--color-fg-muted)] max-w-2xl leading-relaxed">
                    {post.data.description}
                  </p>
                  {post.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <span
                  class="hidden md:inline font-[family-name:var(--font-mono)] text-[color:var(--color-fg-muted)] group-hover:text-[color:var(--color-accent)] group-hover:translate-x-1 transition-transform"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </Container>
  </section>
</Base>
