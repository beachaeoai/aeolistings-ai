---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';
import { faq } from '../lib/faq';

// FAQPage JSON-LD — same set rendered visually below.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

// BreadcrumbList — useful when nested pages get parsed into LLM context.
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${site.url}/faq` },
  ],
};
---
<Base
  title="FAQ"
  description={`Answers to the questions ${site.name} hears most often: how AEO works, what it costs, how long results take, what to expect each month, and how to cancel.`}
  path="/faq"
  schema={[faqSchema, breadcrumbSchema]}
>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-32">
      <div class="mono-label">FAQ · The honest version</div>

      <h1 class="mt-8 text-balance max-w-[22ch]"
          style="font-family: var(--font-serif); font-size: var(--text-display); line-height: 1.02;">
        Questions, answered.
      </h1>

      <p class="mt-10 max-w-2xl text-lg md:text-xl leading-[1.6] text-[color:var(--color-fg-muted)]">
        The same questions every prospect asks at the end of a sales call —
        answered before the call. If you'd rather get this in conversation,
        email <a href={`mailto:${site.email}`} class="link-slide text-[color:var(--color-fg)]">{site.email}</a>.
      </p>
    </Container>
  </section>

  <!-- =========================================================
       ALL QUESTIONS
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-16 md:py-24">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">All questions</div>
          <p class="mt-6 text-[color:var(--color-fg-muted)] max-w-sm leading-[1.6]">
            Structured Q&amp;A is exactly what AI models retrieve and cite. This
            page is itself a demonstration of what we build for clients.
          </p>
          <div class="mt-8 flex flex-wrap gap-2">
            <span class="tag">Retainer</span>
            <span class="tag">Cancel by email</span>
            <span class="tag tag--accent">No annual contracts</span>
          </div>
        </div>

        <div class="border-t border-[color:var(--color-hairline)]">
          {faq.map((item, i) => (
            <details class="group border-b border-[color:var(--color-hairline)]">
              <summary class="list-none cursor-pointer py-6 flex items-start justify-between gap-6 font-[family-name:var(--font-serif)] text-[1.25rem] md:text-[1.5rem] leading-[1.25] tracking-[-0.01em]">
                <span class="flex gap-5 items-baseline">
                  <span class="mono-label shrink-0" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span>{item.question}</span>
                </span>
                <span class="shrink-0 pt-1 font-[family-name:var(--font-sans)] text-[color:var(--color-accent)] transition-transform group-open:rotate-45 text-xl"
                      aria-hidden="true">+</span>
              </summary>
              <div class="pb-6 md:pl-14 pr-2 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-[65ch]">
                {item.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FINAL CTA
       ========================================================= -->
  <section>
    <Container class="py-20 md:py-28 text-center">
      <p class="font-[family-name:var(--font-serif)] italic text-balance mx-auto max-w-3xl"
         style="font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.2;">
        Have a question that isn't answered here?
      </p>
      <div class="mt-10 flex justify-center flex-wrap gap-4">
        <a href={`mailto:${site.email}`} class="btn btn--primary">
          <span>Email us</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href="/contact" class="btn">
          <span>Contact page</span>
        </a>
      </div>
    </Container>
  </section>
</Base>
