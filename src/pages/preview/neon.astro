---
/**
 * Variant C · Modern SaaS / Neon
 *
 * Standalone preview — does NOT use shared Base/Nav/Footer or global.css.
 * All tokens, fonts, and styles are self-contained so the variant can be
 * judged in isolation. Noindex.
 */
import '@fontsource-variable/inter/index.css';
import { site } from '../../lib/site';
import { services } from '../../lib/services';

const pageTitle = 'Neon preview · AEO Listings';
const pageDesc =
  'Variant C — modern SaaS / cyberpunk-premium mockup for AEO Listings, an Answer Engine Optimization agency.';
const year = new Date().getFullYear();
const featured = services.slice(0, 3);
---

<html lang="en" data-variant="neon">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={`${site.url}/preview/neon`} />

    <style is:global>
      :root {
        --ink: #0A0B12;
        --ink-2: #11131C;
        --ink-3: #1A1D2C;
        --fg: #F2F3F8;
        --fg-muted: #A4A8B8;
        --fg-dim: #5C5F6E;
        --hairline: rgba(255, 255, 255, 0.06);
        --hairline-strong: rgba(255, 255, 255, 0.12);
        --accent-a: #7B61FF;
        --accent-b: #00D4FF;
        --accent-grad: linear-gradient(135deg, #7B61FF 0%, #00D4FF 100%);
        --accent-grad-hover: linear-gradient(115deg, #7B61FF 0%, #00D4FF 100%);
        --accent-grad-soft: linear-gradient(
          135deg,
          rgba(123, 97, 255, 0.25),
          rgba(0, 212, 255, 0.25)
        );

        --font-sans: 'Inter Variable', ui-sans-serif, system-ui,
          -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html[data-variant='neon'] {
        background: var(--ink);
        color: var(--fg);
        font-family: var(--font-sans);
        font-feature-settings: 'cv11', 'ss01';
        font-size: 17px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      html[data-variant='neon'] body {
        margin: 0;
        padding: 0;
        background: var(--ink);
        overflow-x: hidden;
      }

      html[data-variant='neon'] a {
        color: inherit;
        text-decoration: none;
      }

      /* Reusable gradient-text helper */
      .nn-grad-text {
        background: var(--accent-grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      /* Shared container */
      .nn-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        position: relative;
      }
      @media (min-width: 768px) {
        .nn-container {
          padding: 0 2.5rem;
        }
      }
      @media (min-width: 1024px) {
        .nn-container {
          padding: 0 4rem;
        }
      }

      /* Small label */
      .nn-label {
        font-size: 0.8125rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--fg-muted);
      }

      /* Top bar */
      .nn-topbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(10, 11, 18, 0.72);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--hairline);
      }
      .nn-topbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 0;
      }
      .nn-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--fg);
      }
      .nn-brand__mark {
        width: 18px;
        height: 18px;
        border-radius: 5px;
        background: var(--accent-grad);
        box-shadow: 0 0 14px rgba(123, 97, 255, 0.5);
      }
      .nn-backlink {
        font-size: 0.8125rem;
        color: var(--fg-muted);
        transition: color 200ms ease;
      }
      .nn-backlink:hover {
        color: var(--fg);
      }

      /* Subtle grid background */
      .nn-grid-bg {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
          linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.035) 1px,
            transparent 1px
          );
        background-size: 56px 56px;
        mask-image: radial-gradient(
          ellipse at center,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 0) 70%
        );
        -webkit-mask-image: radial-gradient(
          ellipse at center,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 0) 70%
        );
        pointer-events: none;
        z-index: 0;
      }

      /* Ambient gradient glow */
      .nn-glow {
        position: absolute;
        border-radius: 50%;
        background: var(--accent-grad-soft);
        filter: blur(120px);
        opacity: 0.5;
        pointer-events: none;
        z-index: 0;
      }
      .nn-glow--hero {
        top: -10%;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 700px;
      }
      .nn-glow--cta {
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 700px;
        height: 400px;
        opacity: 0.35;
      }

      /* Hero */
      .nn-hero {
        position: relative;
        padding: 6rem 0 8rem;
        text-align: center;
        overflow: hidden;
      }
      .nn-hero__inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* Pill badge */
      .nn-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4375rem 0.875rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--hairline-strong);
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--fg-muted);
        letter-spacing: 0.01em;
        position: relative;
      }
      .nn-pill::before {
        content: '';
        position: absolute;
        inset: -1px;
        border-radius: 999px;
        padding: 1px;
        background: var(--accent-grad);
        -webkit-mask:
          linear-gradient(#fff 0 0) content-box,
          linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0.35;
        pointer-events: none;
      }
      .nn-pill__dot {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--accent-b);
        box-shadow: 0 0 8px var(--accent-b);
        animation: nn-pulse 2s ease-in-out infinite;
      }

      @keyframes nn-pulse {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.55;
          transform: scale(0.88);
        }
      }

      .nn-hero__h1 {
        margin: 2rem 0 1.5rem;
        font-size: clamp(3rem, 7vw, 6.5rem);
        font-weight: 500;
        line-height: 1.02;
        letter-spacing: -0.03em;
        max-width: 14ch;
        color: var(--fg);
      }

      .nn-hero__sub {
        max-width: 640px;
        margin: 0 auto 2.5rem;
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--fg-muted);
      }

      .nn-cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      /* Gradient primary button */
      .nn-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8125rem 1.375rem;
        border-radius: 8px;
        background: var(--accent-grad);
        color: #fff;
        font-size: 0.9375rem;
        font-weight: 500;
        letter-spacing: -0.005em;
        box-shadow: 0 0 40px rgba(123, 97, 255, 0.25);
        transition: background 300ms ease, box-shadow 300ms ease;
        border: 0;
        cursor: pointer;
      }
      .nn-btn-primary:hover {
        background: var(--accent-grad-hover);
        box-shadow: 0 0 56px rgba(123, 97, 255, 0.4);
      }
      .nn-btn-primary__arrow {
        transition: transform 200ms ease;
      }
      .nn-btn-primary:hover .nn-btn-primary__arrow {
        transform: translateX(3px);
      }

      /* Glass secondary button */
      .nn-btn-glass {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8125rem 1.375rem;
        border-radius: 8px;
        background: transparent;
        border: 1px solid var(--hairline-strong);
        color: var(--fg);
        font-size: 0.9375rem;
        font-weight: 500;
        transition: background 200ms ease, border-color 200ms ease;
      }
      .nn-btn-glass:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.2);
      }

      /* Section scaffolding */
      .nn-section {
        position: relative;
        padding: 6rem 0;
        border-top: 1px solid var(--hairline);
      }

      /* What we do */
      .nn-what {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      }
      @media (min-width: 900px) {
        .nn-what {
          grid-template-columns: 1fr 2fr;
          gap: 5rem;
        }
      }
      .nn-what__tagline {
        margin-top: 1rem;
        font-size: 1.5rem;
        font-weight: 500;
        line-height: 1.25;
        letter-spacing: -0.015em;
        color: var(--fg-muted);
        max-width: 20ch;
      }
      .nn-what__prose p {
        margin: 0 0 1.5rem;
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--fg);
      }
      .nn-what__prose p:last-child {
        margin-bottom: 0;
      }
      .nn-what__prose strong {
        color: var(--fg);
        font-weight: 500;
      }

      /* Services teaser */
      .nn-services-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 3rem;
        gap: 2rem;
        flex-wrap: wrap;
      }
      .nn-services-head__h2 {
        margin: 1rem 0 0;
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 500;
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--fg);
        max-width: 18ch;
      }
      .nn-services {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
      @media (min-width: 800px) {
        .nn-services {
          grid-template-columns: repeat(3, 1fr);
        }
      }
      .nn-card {
        position: relative;
        padding: 1.75rem;
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid var(--hairline);
        border-radius: 14px;
        transition: border-color 200ms ease, transform 200ms ease,
          background 200ms ease;
      }
      .nn-card:hover {
        border-color: rgba(123, 97, 255, 0.5);
        background: rgba(255, 255, 255, 0.035);
        transform: translateY(-2px);
      }
      .nn-card__num {
        display: block;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        margin-bottom: 2rem;
      }
      .nn-card__name {
        margin: 0 0 0.625rem;
        font-size: 1.375rem;
        font-weight: 500;
        letter-spacing: -0.015em;
        color: var(--fg);
      }
      .nn-card__tag {
        margin: 0 0 1.75rem;
        font-size: 0.9375rem;
        line-height: 1.55;
        color: var(--fg-muted);
      }
      .nn-card__link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--fg);
      }
      .nn-card__link-arrow {
        transition: transform 200ms ease;
      }
      .nn-card:hover .nn-card__link-arrow {
        transform: translateX(4px);
      }

      /* Stats */
      .nn-stats__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      }
      @media (min-width: 800px) {
        .nn-stats__grid {
          grid-template-columns: repeat(3, 1fr);
          gap: 2rem;
        }
      }
      .nn-stat__num {
        display: block;
        font-size: clamp(5rem, 12vw, 11.25rem);
        font-weight: 500;
        line-height: 0.95;
        letter-spacing: -0.04em;
        background: var(--accent-grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .nn-stat__label {
        margin-top: 1rem;
        font-size: 0.9375rem;
        line-height: 1.45;
        color: var(--fg-muted);
        max-width: 22ch;
      }

      /* CTA card */
      .nn-cta-wrap {
        position: relative;
        overflow: hidden;
      }
      .nn-cta-card {
        position: relative;
        z-index: 1;
        max-width: 900px;
        margin: 0 auto;
        padding: 4rem 2rem;
        text-align: center;
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--hairline-strong);
        border-radius: 20px;
      }
      @media (min-width: 720px) {
        .nn-cta-card {
          padding: 5rem 4rem;
        }
      }
      .nn-cta-card__h2 {
        margin: 0 0 1.25rem;
        font-size: clamp(2rem, 4vw, 3.25rem);
        font-weight: 500;
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--fg);
      }
      .nn-cta-card__sub {
        margin: 0 auto 2.5rem;
        max-width: 52ch;
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--fg-muted);
      }

      /* Footer */
      .nn-footer {
        border-top: 1px solid var(--hairline);
        padding: 2rem 0;
      }
      .nn-footer-inner {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-start;
        justify-content: space-between;
      }
      @media (min-width: 640px) {
        .nn-footer-inner {
          flex-direction: row;
          align-items: center;
        }
      }
      .nn-footer__copy {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        font-size: 0.8125rem;
        color: var(--fg-muted);
      }
      .nn-footer__dot {
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: var(--accent-b);
        box-shadow: 0 0 10px var(--accent-b);
        animation: nn-pulse 2s ease-in-out infinite;
      }
      .nn-footer__tag {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--fg-dim);
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0s !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0s !important;
        }
      }
    </style>
  </head>

  <body>
    <!-- Top bar -->
    <header class="nn-topbar">
      <div class="nn-container nn-topbar-inner">
        <span class="nn-brand">
          <span class="nn-brand__mark" aria-hidden="true"></span>
          {site.name}
        </span>
        <a class="nn-backlink" href="/preview">&larr; Back to preview</a>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="nn-hero">
        <div class="nn-grid-bg" aria-hidden="true"></div>
        <div class="nn-glow nn-glow--hero" aria-hidden="true"></div>
        <div class="nn-container">
          <div class="nn-hero__inner">
            <span class="nn-pill">
              <span class="nn-pill__dot" aria-hidden="true"></span>
              v0.1 &middot; Answer Engine Optimization
            </span>

            <h1 class="nn-hero__h1">
              Be the answer <span class="nn-grad-text">AI</span> returns.
            </h1>

            <p class="nn-hero__sub">
              Search is collapsing into a single synthesized reply. We engineer
              the entity signals, schema, and retrieval-ready content that make
              your company the sentence ChatGPT, Claude, Perplexity, and Gemini
              return &mdash; before a prospect ever opens a browser tab.
            </p>

            <div class="nn-cta-row">
              <a class="nn-btn-primary" href="/contact">
                <span>Start a project</span>
                <span class="nn-btn-primary__arrow" aria-hidden="true">
                  &rarr;
                </span>
              </a>
              <a class="nn-btn-glass" href="/services">See services</a>
            </div>
          </div>
        </div>
      </section>

      <!-- What we do -->
      <section class="nn-section">
        <div class="nn-container nn-what">
          <div>
            <span class="nn-label">01 &middot; The method</span>
            <p class="nn-what__tagline">
              Optimized for the model, not the ranking.
            </p>
          </div>
          <div class="nn-what__prose">
            <p>
              Answer Engine Optimization is the practice of making a business
              legibly retrievable by large language models.
              <strong>ChatGPT</strong>, <strong>Claude</strong>,
              <strong>Perplexity</strong>, and <strong>Gemini</strong> no
              longer rank ten links &mdash; they synthesize a single answer
              from a narrow set of cited sources. AEO determines whether yours
              is one of them.
            </p>
            <p>
              The work starts with the entity graph: schema.org markup,
              Wikidata alignment, and the canonical descriptions that let a
              model know unambiguously who you are and what you sell. From
              there we rebuild content for retrieval &mdash; question-led
              headings, atomic factual paragraphs, and entity-dense openings
              that survive the chunking step inside every RAG pipeline.
            </p>
            <p>
              Because the surface is new, we measure what almost no one
              measures. A recurring set of buyer-intent prompts runs against
              every major answer engine each month, returning citation share,
              sentiment, and competitive presence. Classical rank tracking is
              blind to this layer. Our practice was built to see it.
            </p>
          </div>
        </div>
      </section>

      <!-- Services teaser -->
      <section class="nn-section">
        <div class="nn-container">
          <div class="nn-services-head">
            <div>
              <span class="nn-label">02 &middot; Services</span>
              <h2 class="nn-services-head__h2">
                Three surfaces. One practice.
              </h2>
            </div>
            <a class="nn-btn-glass" href="/services">
              <span>All services</span>
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
          <div class="nn-services">
            {
              featured.map((s) => (
                <article class="nn-card">
                  <span class="nn-card__num nn-grad-text">{s.num}</span>
                  <h3 class="nn-card__name">{s.name}</h3>
                  <p class="nn-card__tag">{s.tagline}</p>
                  <a class="nn-card__link" href={`/services#${s.id}`}>
                    <span>Learn more</span>
                    <span class="nn-card__link-arrow" aria-hidden="true">
                      &rarr;
                    </span>
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Stats -->
      <section class="nn-section">
        <div class="nn-grid-bg" aria-hidden="true"></div>
        <div class="nn-container" style="position: relative; z-index: 1;">
          <span class="nn-label" style="display: block; margin-bottom: 3rem;">
            03 &middot; The shift, in numbers
          </span>
          <div class="nn-stats__grid">
            <div>
              <span class="nn-stat__num">1B+</span>
              <p class="nn-stat__label">ChatGPT queries per day</p>
            </div>
            <div>
              <span class="nn-stat__num">1&ndash;3</span>
              <p class="nn-stat__label">
                Sources cited per synthesized answer
              </p>
            </div>
            <div>
              <span class="nn-stat__num">70%</span>
              <p class="nn-stat__label">Of sites invisible to LLM retrieval</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="nn-section nn-cta-wrap">
        <div class="nn-glow nn-glow--cta" aria-hidden="true"></div>
        <div class="nn-container">
          <div class="nn-cta-card">
            <h2 class="nn-cta-card__h2">
              Ready to be the <span class="nn-grad-text">synthesized</span>
              answer?
            </h2>
            <p class="nn-cta-card__sub">
              Two-week sprints, month-to-month retainers, and measurement that
              actually reflects what&rsquo;s happening inside the model. Tell
              us where you want to show up.
            </p>
            <div class="nn-cta-row">
              <a class="nn-btn-primary" href="/contact">
                <span>Start a project</span>
                <span class="nn-btn-primary__arrow" aria-hidden="true">
                  &rarr;
                </span>
              </a>
              <a class="nn-btn-glass" href={`mailto:${site.email}`}>
                {site.email}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="nn-footer">
      <div class="nn-container nn-footer-inner">
        <span class="nn-footer__copy">
          <span class="nn-footer__dot" aria-hidden="true"></span>
          &copy; {year} {site.name}
        </span>
        <span class="nn-footer__tag">Answer Engine Optimization</span>
      </div>
    </footer>
  </body>
</html>
