---
/**
 * Wordmark preview — 3 logo drafts in editorial type system.
 * Shows each at display, standard, and nav-size on both paper and ink backgrounds.
 * Temporary page. Delete once user picks a wordmark.
 */
import '@fontsource/instrument-serif/index.css';
import '@fontsource/instrument-sans/index.css';

const drafts = [
  {
    id: 1,
    name: 'Classic',
    file: '/logo-drafts/wordmark-1-classic.svg',
    note: 'Single-line serif lockup. Lowercase = approachable. Italic .ai = subtle tech signal. Most versatile — reads clearly at any size.',
  },
  {
    id: 2,
    name: 'Masthead',
    file: '/logo-drafts/wordmark-2-masthead.svg',
    note: 'Editorial masthead treatment. Italic "Listings" + thin rule + descriptor line. Feels like a publication nameplate — The Economist / NYT energy. Takes more space but earns it.',
  },
  {
    id: 3,
    name: 'Stacked',
    file: '/logo-drafts/wordmark-3-stacked.svg',
    note: 'Bold "AEO" as primary mark, "LISTINGS" as tracked caps underneath. Most confident / architectural. Works well as a small mark on its own.',
  },
];

const sizes = [
  { label: 'Display (page hero)', h: 140 },
  { label: 'Standard (card / section)', h: 80 },
  { label: 'Nav bar', h: 32 },
];
---
<html lang="en" data-variant="wordmarks">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Wordmark preview · AEO Listings</title>
    <meta name="robots" content="noindex, nofollow" />

    <style is:global>
      :root {
        --paper: #FAF8F1;
        --paper-2: #F4F1E8;
        --ink: #1A1A1A;
        --ink-muted: #6B6B6B;
        --ink-dim: #9A9A9A;
        --hairline: #E5E1D6;
        --accent: #8B2F2F;
        --font-serif: 'Instrument Serif', Georgia, serif;
        --font-sans: 'Instrument Sans', -apple-system, Helvetica, sans-serif;
      }
      * { box-sizing: border-box; }
      html[data-variant='wordmarks'] {
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      body { margin: 0; }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
      }
      .eyebrow {
        font-family: var(--font-sans);
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-muted);
        margin-bottom: 1rem;
      }
      h1 {
        font-family: var(--font-serif);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        line-height: 1.05;
        font-weight: 400;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
      }
      .lede {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        color: var(--ink-muted);
        max-width: 52ch;
        font-style: italic;
        margin-bottom: 4rem;
      }
      .draft {
        border-top: 1px solid var(--hairline);
        padding: 3.5rem 0 4rem;
      }
      .draft:last-child { border-bottom: 1px solid var(--hairline); }
      .draft-head {
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
        margin-bottom: 2rem;
      }
      .draft-num {
        font-family: var(--font-sans);
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        color: var(--ink-dim);
      }
      .draft-name {
        font-family: var(--font-serif);
        font-size: 2rem;
        font-weight: 400;
      }
      .draft-note {
        max-width: 60ch;
        color: var(--ink-muted);
        margin-bottom: 3rem;
      }
      .size-row {
        display: grid;
        grid-template-columns: 180px 1fr 1fr;
        gap: 1.5rem;
        align-items: center;
        padding: 2rem 0;
        border-top: 1px solid var(--hairline);
      }
      .size-label {
        font-family: var(--font-sans);
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      .logo-cell {
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        min-height: 180px;
      }
      .logo-cell--paper { background: var(--paper-2); }
      .logo-cell--ink { background: var(--ink); }
      .logo-cell img { display: block; max-width: 100%; }
      .logo-cell--ink img { filter: invert(1); }
      .cell-label {
        font-family: var(--font-sans);
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-dim);
        margin-bottom: 0.5rem;
      }
      .footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--hairline);
        font-size: 0.9rem;
        color: var(--ink-muted);
      }
      @media (max-width: 760px) {
        .size-row { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="eyebrow">[ Preview / Wordmark ]</div>
      <h1>Three marks. One brand.</h1>
      <p class="lede">
        Each wordmark is shown at three sizes — the size it'll appear in the hero,
        in section callouts, and in the nav bar. Also shown on paper and on ink,
        because the mark has to work in both. Pick one; we wire it in and retire the rest.
      </p>

      {drafts.map((d) => (
        <section class="draft">
          <div class="draft-head">
            <span class="draft-num">[{d.id}]</span>
            <span class="draft-name">{d.name}</span>
          </div>
          <p class="draft-note">{d.note}</p>

          {sizes.map((s) => (
            <div class="size-row">
              <div>
                <div class="size-label">{s.label}</div>
                <div style="font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-dim); margin-top: 0.25rem;">{s.h}px tall</div>
              </div>
              <div>
                <div class="cell-label">On paper</div>
                <div class="logo-cell logo-cell--paper">
                  <img src={d.file} alt={`Wordmark ${d.id} ${d.name} on paper`} style={`height: ${s.h}px;`} />
                </div>
              </div>
              <div>
                <div class="cell-label">On ink</div>
                <div class="logo-cell logo-cell--ink">
                  <img src={d.file} alt={`Wordmark ${d.id} ${d.name} on ink`} style={`height: ${s.h}px;`} />
                </div>
              </div>
            </div>
          ))}
        </section>
      ))}

      <p class="footer">
        To pick: reply with <strong>1</strong>, <strong>2</strong>, or <strong>3</strong>.
        Mixing elements (e.g. "1 but with the color from 3") is allowed.
      </p>
    </div>
  </body>
</html>
