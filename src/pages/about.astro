---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';

// AboutPage schema
const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About ${site.name}`,
  url: site.url + '/about',
  description:
    `${site.name} is an Answer Engine Optimization agency for home service pros and local professionals.`,
  about: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    email: site.email,
  },
};

// Person schema for the founder
const founderSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.founder.name,
  jobTitle: site.founder.title,
  worksFor: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  email: site.email,
};

const principles = [
  {
    num: '01',
    title: 'Answers first. Jargon never.',
    body: "Every page we write — and every page we touch for a client — answers the actual question in the first paragraph. AI models reward clarity. Buyers reward clarity. We haven't found a single case where being clever beats being clear.",
  },
  {
    num: '02',
    title: 'Measure what AI sees.',
    body: "We don't track rankings. We track citations: how often AI chatbots name your business, in what sentiment, and against which competitors. If we don't move that number, we haven't done our job.",
  },
  {
    num: '03',
    title: 'Retainer, no lock-in.',
    body: "Cancel by email. No annual contracts, no termination fees, no surprise invoices. The work has to earn its keep every month — otherwise it shouldn't exist.",
  },
  {
    num: '04',
    title: 'We have to pass our own test.',
    body: "If this website doesn't get recommended by ChatGPT, Claude, and Perplexity when someone asks for an AEO agency, we have no business selling the same outcome to you.",
  },
];
---
<Base
  title="About"
  description={`About ${site.name} — an Answer Engine Optimization agency for home service pros and local professionals.`}
  path="/about"
  schema={[aboutSchema, founderSchema]}
>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-32">
      <div class="mono-label">About · The agency</div>

      <h1 class="mt-8 text-balance max-w-[20ch]"
          style="font-family: var(--font-serif); font-size: var(--text-display); line-height: 1.02;">
        An agency built for the way people actually find local businesses now.
      </h1>

      <p class="mt-10 max-w-2xl text-lg md:text-xl leading-[1.6] text-[color:var(--color-fg-muted)]">
        {site.name} is a small, focused Answer Engine Optimization agency working with home
        service pros and local professionals. We help your business get recommended by
        the AI chatbots your next customer is already asking.
      </p>
    </Container>
  </section>

  <!-- =========================================================
       THESIS
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 md:gap-20">
        <div>
          <div class="mono-label">01 · Why we exist</div>
          <h2 class="mt-5"
              style="font-size: var(--text-display); line-height: 1.05;">
            The way local recommendations happen just changed.
          </h2>
        </div>
        <div class="space-y-6 text-[1.0625rem] leading-[1.65] max-w-[60ch]">
          <p>
            For the last twenty years, when someone needed a plumber, they typed it into Google
            and scrolled. That habit is breaking. A growing share of prospects now open
            ChatGPT — or ask Google's AI Overview, or Perplexity, or Claude — and get back a
            single recommendation.
          </p>
          <p class="text-[color:var(--color-fg-muted)]">
            Most local businesses are structurally invisible to these systems. Their Google
            Business Profile is thin. Their citations don't match across directories. Their
            website doesn't answer questions in a form AI can cleanly quote. When the
            chatbot picks a name to recommend, it picks someone else.
          </p>
          <blockquote class="pullquote">
            The businesses getting recommended by AI today aren't necessarily the best ones.
            They're the ones that made it easy for the model to recommend them.
          </blockquote>
          <p class="text-[color:var(--color-fg-muted)]">
            We exist to fix that gap for local service businesses. Most SEO shops
            don't understand how AI models retrieve and cite sources; most AI tools don't
            understand local service businesses. We sit in the middle.
          </p>
          <p class="text-[color:var(--color-fg-muted)]">
            We work on retainer with a small roster of clients. No annual contracts.
            We're not shy about how the work gets done — the <a href="/services" class="link-slide text-[color:var(--color-fg)]">services page</a> and the <a href="/#faq" class="link-slide text-[color:var(--color-fg)]">FAQ</a> describe the whole practice. The value isn't in the playbook. It's in running it for you — correctly, and every month the models change.
          </p>
          <div class="pt-4 flex flex-wrap gap-2">
            <span class="tag">Home service pros</span>
            <span class="tag">Local professionals</span>
            <span class="tag">No annual contracts</span>
            <span class="tag tag--accent">Retainer</span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FOUNDER — portrait + bio (placeholders pending user content)
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="mono-label">02 · Who runs it</div>
      <h2 class="mt-5"
          style="font-size: var(--text-display); line-height: 1.05;">
        Small roster.<br />Senior hands only.
      </h2>

      <div class="mt-14 grid md:grid-cols-[minmax(0,320px)_1fr] gap-12 md:gap-16 items-start">
        <!-- Portrait placeholder -->
        <div class="relative aspect-square border border-[color:var(--color-hairline)] bg-[color:var(--color-bg-2)] flex items-center justify-center">
          <span class="mono-label">Portrait · pending</span>
        </div>

        <div>
          <h3 class="font-[family-name:var(--font-serif)] text-[2rem] md:text-[2.5rem] leading-[1.05] tracking-[-0.01em]">
            {site.founder.name}
          </h3>
          <p class="mt-3 mono-label">
            {site.founder.title} · {site.name}
          </p>

          <div class="mt-8 space-y-5 text-[1.0625rem] leading-[1.7] max-w-[58ch]">
            <p>
              [PLACEHOLDER] Short bio paragraph one. Where the founder came from, what they
              built before, and why traditional SEO stopped solving the real problem. Written
              in third person, three to four sentences, concrete and specific — mention a
              role, a result, a number.
            </p>
            <p class="text-[color:var(--color-fg-muted)]">
              [PLACEHOLDER] Short bio paragraph two. Why they started {site.name}, who they
              prefer to work with, and the one opinion that runs through every engagement.
            </p>
          </div>

          <div class="mt-10 border-t border-[color:var(--color-hairline)] pt-8">
            <div class="mono-label mb-4">Credentials</div>
            <ul class="space-y-3 text-[color:var(--color-fg-muted)] leading-[1.6]">
              <li class="flex gap-3">
                <span class="shrink-0 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                <span>[PLACEHOLDER] Prior role or notable outcome</span>
              </li>
              <li class="flex gap-3">
                <span class="shrink-0 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                <span>[PLACEHOLDER] Prior role or notable outcome</span>
              </li>
              <li class="flex gap-3">
                <span class="shrink-0 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                <span>[PLACEHOLDER] Publication, talk, or certification</span>
              </li>
              <li class="flex gap-3">
                <span class="shrink-0 text-[color:var(--color-accent)] font-[family-name:var(--font-serif)]" aria-hidden="true">·</span>
                <span>[PLACEHOLDER] Area of focus or specialty</span>
              </li>
            </ul>
          </div>

          <div class="mt-10">
            <a href={`mailto:${site.email}`} class="link-slide text-[color:var(--color-fg)]">
              {site.email}
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- =========================================================
       PRINCIPLES
       ========================================================= -->
  <section class="border-b border-[color:var(--color-hairline)]">
    <Container class="py-20 md:py-28">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <div class="mono-label">03 · How we operate</div>
          <h2 class="mt-5"
              style="font-size: var(--text-display); line-height: 1.05;">
            Four rules.<br />We don't break them.
          </h2>
        </div>
        <p class="max-w-sm text-[color:var(--color-fg-muted)] leading-[1.6]">
          These shape every engagement, every deliverable, and every invoice.
        </p>
      </div>

      <div class="mt-14 grid gap-12 md:grid-cols-2">
        {principles.map((p) => (
          <div>
            <div class="font-[family-name:var(--font-sans)] text-[0.75rem] uppercase tracking-[0.18em] text-[color:var(--color-accent)] font-semibold">
              Principle {p.num}
            </div>
            <h3 class="mt-4 font-[family-name:var(--font-serif)] text-[1.75rem] leading-[1.1] tracking-[-0.01em]">
              {p.title}
            </h3>
            <p class="mt-4 text-[color:var(--color-fg-muted)] leading-[1.65] max-w-[52ch]">
              {p.body}
            </p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- =========================================================
       FINAL CTA
       ========================================================= -->
  <section>
    <Container class="py-24 md:py-36 text-center">
      <p class="font-[family-name:var(--font-serif)] italic text-balance mx-auto max-w-3xl"
         style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.2;">
        Thirty minutes. No pitch. Bring a question.
      </p>
      <p class="mt-6 max-w-xl mx-auto text-[color:var(--color-fg-muted)] leading-[1.65]">
        If you'd like to talk through how AI chatbots are treating your business today,
        or how your competitors are showing up without you, we'll give you an honest
        answer on a call.
      </p>
      <div class="mt-10 flex justify-center flex-wrap gap-4">
        <a href="/contact" class="btn btn--primary">
          <span>Start a project</span>
          <span aria-hidden="true">→</span>
        </a>
        <a href={`mailto:${site.email}`} class="btn">
          <span>Email us directly</span>
        </a>
      </div>
    </Container>
  </section>
</Base>
