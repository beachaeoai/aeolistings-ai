---
import { site } from '../lib/site';
import Container from './Container.astro';
import Wordmark from './Wordmark.astro';

const year = new Date().getFullYear();
---
<footer class="border-t border-[color:var(--color-hairline)] mt-24 md:mt-32">
  <Container class="py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-[2fr_1fr_1fr]">
      <div>
        <a href="/" aria-label={`${site.name} — home`} class="inline-block text-[color:var(--color-fg)]">
          <Wordmark class="h-8 md:h-10 w-auto" />
        </a>
        <p class="mt-6 font-[family-name:var(--font-serif)] text-2xl md:text-[1.75rem] leading-[1.2] text-balance max-w-md text-[color:var(--color-fg)]">
          {site.tagline}
        </p>
        <a href="/contact" class="btn btn--primary mt-8">
          <span>Get in touch</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div>
        <div class="mono-label">Site</div>
        <ul class="mt-4 space-y-3 font-[family-name:var(--font-sans)]">
          {site.nav.map(({ label, href }) => (
            <li>
              <a href={href} class="link-slide text-[color:var(--color-fg)] hover:text-[color:var(--color-accent)]">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <div class="mono-label">Contact</div>
        <ul class="mt-4 space-y-3 font-[family-name:var(--font-sans)]">
          <li>
            <a href={`mailto:${site.email}`} class="link-slide break-all text-[color:var(--color-fg)] hover:text-[color:var(--color-accent)]">
              {site.email}
            </a>
          </li>
          <li class="text-[color:var(--color-fg-muted)]">{site.location}</li>
          <li class="text-[color:var(--color-fg-dim)] text-[0.9rem]">Cancel anytime by email</li>
        </ul>
      </div>
    </div>
  </Container>

  <div class="border-t border-[color:var(--color-hairline)]">
    <Container class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 py-5 font-[family-name:var(--font-sans)] text-[0.8125rem] text-[color:var(--color-fg-muted)]">
      <div>© {year} {site.name}. All rights reserved.</div>
      <div class="uppercase tracking-[0.14em] text-[color:var(--color-fg-dim)] font-medium">
        Answer Engine Optimization
      </div>
    </Container>
  </div>
</footer>
