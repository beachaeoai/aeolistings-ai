---
import { site } from '../lib/site';
import Container from './Container.astro';

const year = new Date().getFullYear();
---
<footer class="border-t border-[color:var(--color-hairline)] mt-24">
  <Container class="py-16">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr]">
      <div>
        <div class="mono-label">[ Agency ]</div>
        <p class="mt-3 text-2xl md:text-3xl font-medium tracking-tight text-balance max-w-md">
          {site.tagline}
        </p>
        <a href="/contact" class="btn btn--primary mt-6">
          Get in touch
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div>
        <div class="mono-label">[ Site ]</div>
        <ul class="mt-3 space-y-2 font-[family-name:var(--font-mono)] text-sm">
          {site.nav.map(({ label, href }) => (
            <li>
              <a href={href} class="link-slide hover:text-[color:var(--color-accent)]">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <div class="mono-label">[ Contact ]</div>
        <ul class="mt-3 space-y-2 font-[family-name:var(--font-mono)] text-sm">
          <li>
            <a href={`mailto:${site.email}`} class="link-slide break-all hover:text-[color:var(--color-accent)]">
              {site.email}
            </a>
          </li>
          <li class="text-[color:var(--color-fg-muted)]">{site.location}</li>
        </ul>
      </div>
    </div>
  </Container>

  <div class="border-t border-[color:var(--color-hairline)]">
    <Container class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 py-5 font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.08em] text-[color:var(--color-fg-muted)]">
      <div>© {year} {site.name}. All rights reserved.</div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--color-accent)]" aria-hidden="true"></span>
        <span>Built to rank in answer engines.</span>
      </div>
    </Container>
  </div>
</footer>
