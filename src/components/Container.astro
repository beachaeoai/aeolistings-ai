---
/**
 * Max-width wrapper with consistent horizontal padding.
 * Use on every top-level section to keep content aligned.
 */
interface Props {
  as?: string;
  class?: string;
  wide?: boolean;
}
const { as: Tag = 'div', class: className = '', wide = false } = Astro.props;
const maxW = wide ? 'max-w-[1440px]' : 'max-w-[1200px]';
---
<Tag class:list={[maxW, 'mx-auto px-6 md:px-10 lg:px-16', className]}>
  <slot />
</Tag>
