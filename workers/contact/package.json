{
  "name": "aeolistings-contact-worker",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker that receives /contact form submissions and forwards via Resend.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "secret:resend": "wrangler secret put RESEND_API_KEY",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.30.0"
  }
}
